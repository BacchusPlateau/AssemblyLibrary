   113 				;=========================================================================
   114 				; drawSpriteSolo - Preserved for all the great comments.
   115 				;
   116 				; Draws a 16-pixel-wide, 12-row-tall sprite (the spaceship "Beowulf")
   117 				; from a packed bitmap table in memory, onto the GR.8 screen.
   118 				;
   119 				; The sprite data is stored as 24 bytes total: each row of the sprite
   120 				; is 16 pixels wide, which needs 2 bytes per row (8 bits per byte),
   121 				; and there are 12 rows, so 2 bytes × 12 rows = 24 bytes.
   122 				;
   123 				; ON ENTRY: spritePtr_lo/spritePtr_hi point to the start of the sprite
   124 				;           bitmap data (24 consecutive bytes)
   125 				;           baseX_lo/baseX_hi = screen X coordinate of the sprite's
   126 				;           top-left corner (16-bit, since X can go up to 319)
   127 				;           baseY = screen Y coordinate of the sprite's top-left corner
   128 				; ON EXIT:  every "1" bit in the sprite data has been plotted as a
   129 				;           pixel on screen at the correct offset from (baseX, baseY)
   130 				;=========================================================================
   131 3088			        .proc drawSpriteSolo
   132
   133 3088 A9 00 85 AA		        mva #0 spriteRow       ; spriteRow = 0 — tracks which row of the
   134 				                                ; sprite (0-11) we're currently drawing
   135 308C A9 00 85 AC		        mva #0 byteCount       ; byteCount = 0 — tracks how many of the
   136 				                                ; 24 total sprite bytes we've processed
   137 3090 A9 00 85 AB		        mva #0 columnBase      ; columnBase = 0 — tracks whether we're in
   138 				                                ; the LEFT half (0-7) or RIGHT half (8-15)
   139 				                                ; of the current row, since each row needs
   140 				                                ; two bytes (left byte then right byte)
   141
   142 				;-------------------------------------------------------------------------
   143 				; Outer loop: process one byte of sprite data per pass.
   144 				; Each byte represents 8 horizontal pixels (1 bit = 1 pixel).
   145 				;-------------------------------------------------------------------------
   146 3094			spriteloop:
   147 3094 A0 00		        ldy #0                          ; Y = 0 (offset for indirect read)
   148 3096 B1 A6		        lda (spritePtr_lo),y             ; A = memory[spritePtr + Y]
   149 				                                        ; fetch the current sprite byte
   150 				                                        ; using our 16-bit pointer
   151 3098 85 A8		        sta spriteByte                  ; save it — we'll be testing each
   152 				                                        ; bit of it one at a time below
   153
   154 309A A9 80 85 A9		        mva #%10000000 spriteMask       ; spriteMask = %10000000
   155 				                                        ; start by testing the LEFTMOST
   156 				                                        ; bit (bit 7) of this byte first
   157 309E A9 00 85 B0		        mva #0 bitCounter               ; bitCounter = 0 — tracks which of
   158 				                                        ; the 8 bits within this byte
   159 				                                        ; we're currently testing (0-7)
   160
   161 				;-------------------------------------------------------------------------
   162 				; Inner loop: test each of the 8 bits in the current sprite byte.
   163 				; If a bit is "1" we plot a pixel there; if "0" we skip it (background).
   164 				;-------------------------------------------------------------------------
   165 30A2			bittest:
   166 30A2 A5 A8		        lda spriteByte                  ; A = the sprite byte we saved
   167 30A4 25 A9		        and spriteMask                  ; A = A AND spriteMask
   168 				                                        ; isolates just the one bit we
   169 				                                        ; care about this pass — result
   170 				                                        ; is 0 if that bit was clear,
   171 				                                        ; non-zero if that bit was set
   172 30A6 F0 1A		        beq skipbit                     ; if the bit was 0 (background),
   173 				                                        ; skip plotting and move on
   174
   175 				        ; --- this bit is "1" — calculate where on screen it belongs ---
   176
   177 				        ; plotX = baseX + columnBase + bitCounter  (16-bit safe addition)
   178 				        ; columnBase shifts us into the left (0) or right (8) half of
   179 				        ; the row, and bitCounter adds the specific pixel offset (0-7)
   180 				        ; within that half — together they give the pixel's column
   181 				        ; position relative to the sprite's top-left corner.
   182 30A8 A5 AD		        lda baseX_lo                    ; A = low byte of sprite's base X
   183 30AA 18			        clc                             ; clear carry before first add
   184 30AB 65 AB		        adc columnBase                  ; A += columnBase (0 or 8)
   185 30AD 18			        clc                             ; clear carry again — columnBase
   186 				                                        ; and bitCounter are both small
   187 				                                        ; values (0-15) so we re-clear
   188 				                                        ; to be explicit/safe before the
   189 				                                        ; second addition
   190 30AE 65 B0		        adc bitCounter                  ; A += bitCounter (0-7)
   191 30B0 85 80		        sta plotX_lo                    ; plotX_lo = final low byte
   192 30B2 A5 AE		        lda baseX_hi                    ; A = high byte of sprite's base X
   193 30B4 69 00		        adc #0                          ; propagate any carry from the
   194 				                                        ; low byte additions above into
   195 				                                        ; the high byte (16-bit safe)
   196 30B6 85 81		        sta plotX_hi                    ; plotX_hi = final high byte
   197
   198 				        ; plotY = baseY + spriteRow
   199 				        ; simple 8-bit addition since Y only ranges 0-191 on screen
   200 30B8 A5 AF		        lda baseY                       ; A = sprite's base Y coordinate
   201 30BA 18			        clc                             ; clear carry before adding
   202 30BB 65 AA		        adc spriteRow                   ; A += spriteRow (0-11)
   203 30BD 85 82		        sta plotY                       ; plotY = final row position
   204
   205 				        ; plotPoint destroys plotX_lo/plotX_hi during its internal
   206 				        ; division — but we don't need those values again until we
   207 				        ; recalculate them fresh on the next bit, so no save/restore
   208 				        ; is needed here (unlike in drawLine where we reused plotX
   209 				        ; across iterations without recalculating it each time)
   210 30BF 20 59 35		        jsr plotPoint                   ; plot this single pixel!
   211
   212 30C2			skipbit:
   213 30C2 46 A9		        lsr spriteMask                  ; shift the mask right one
   214 				                                        ; position — moves us from
   215 				                                        ; testing bit 7 down to bit 6,
   216 				                                        ; then bit 5, etc. on later passes
   217 30C4 E6 B0		        inc bitCounter                  ; bitCounter++ — advance to the
   218 				                                        ; next pixel position (0 through 7)
   219 30C6 A5 B0		        lda bitCounter
   220 30C8 C9 08		        cmp #8                          ; have we tested all 8 bits in
   221 				                                        ; this byte yet?
   222 30CA D0 D6		        bne bittest                     ; no — go test the next bit
   223
   224 				;-------------------------------------------------------------------------
   225 				; Finished all 8 bits of the current byte. Advance to the next byte
   226 				; in the sprite data, and figure out whether that next byte is the
   227 				; right half of the SAME row, or the left half of the NEXT row.
   228 				;-------------------------------------------------------------------------
   229
   230 				        ; advance the 16-bit sprite data pointer to the next byte
   231 30CC E6 A6		        inc spritePtr_lo
   232 30CE D0 02		        bne noCarry                     ; if low byte didn't wrap to 0,
   233 				                                        ; no need to touch the high byte
   234 30D0 E6 A7		        inc spritePtr_hi                ; low byte wrapped — carry into
   235 				                                        ; the high byte (16-bit increment)
   236 30D2			noCarry:
   237 				        ; columnBase toggles between 0 and 8 each time we finish a byte.
   238 				        ; Since each row is 16 pixels wide but each byte only covers 8
   239 				        ; pixels, every row needs exactly TWO bytes: one for columns
   240 				        ; 0-7 (columnBase=0) and one for columns 8-15 (columnBase=8).
   241 30D2 A5 AB		        lda columnBase
   242 30D4 F0 09		        beq setTo8                      ; if columnBase was 0 (we just
   243 				                                        ; finished the LEFT half), switch
   244 				                                        ; to 8 for the RIGHT half next
   245 				        ; columnBase was 8 — we just finished the RIGHT half of a row,
   246 				        ; meaning the entire row (both bytes) is now complete.
   247 30D6 A9 00 85 AB		        mva #0 columnBase                ; reset columnBase back to 0
   248 				                                        ; for the start of the next row
   249 30DA E6 AA		        inc spriteRow                   ; spriteRow++ — move down to the
   250 				                                        ; next row of the sprite
   251 30DC 4C E3 30		        jmp afterToggle
   252 30DF			setTo8:
   253 30DF A9 08 85 AB		        mva #8 columnBase                ; switch to the right half (8-15)
   254 				                                        ; of the CURRENT row — spriteRow
   255 				                                        ; does NOT increment here since
   256 				                                        ; we're still on the same row
   257 30E3			afterToggle:
   258
   259 30E3 E6 AC		        inc byteCount                    ; byteCount++ — one more of the
   260 				                                        ; 24 total sprite bytes processed
   261 30E5 A5 AC		        lda byteCount
   262 30E7 C9 18		        cmp #24                          ; have we processed all 24 bytes
   263 				                                        ; (2 bytes × 12 rows) yet?
   264 30E9 D0 A9		        bne spriteloop                   ; no — go process the next byte
   265
   266 30EB 60			        rts                              ; yes — the entire sprite has
   267 				                                        ; been drawn, return to caller
   268 				        .endp
   269
   270 				;=========================================================================================
   271 30EC			.proc eraseSprite
   272
   273 				        ; save the caller's original spritePtr — see drawSprite for
   274 				        ; why this matters (pointer would otherwise drift forward
   275 				        ; by 24 bytes every call)
   276 30EC A5 A6		        lda spritePtr_lo
   277 30EE 48			        pha
   278 30EF A5 A7		        lda spritePtr_hi
   279 30F1 48			        pha
   280
   281 30F2 A9 00 85 AA		        mva #0 spriteRow
   282 30F6 A9 00 85 AC		        mva #0 byteCount
   283 30FA A9 00 85 AB		        mva #0 columnBase
   284
   285 30FE			eraseloop:
   286 30FE A0 00		        ldy #0
   287 3100 B1 A6		        lda (spritePtr_lo),y
   288 3102 85 A8		        sta spriteByte
   289
   290 3104 A9 80 85 A9		        mva #%10000000 spriteMask
   291 3108 A9 00 85 B0		        mva #0 bitCounter
   292
   293 310C			erasebittest:
   294 310C A5 A8		        lda spriteByte
   295 310E 25 A9		        and spriteMask
   296 3110 F0 1A		        beq eraseskipbit
   297
   298 3112 A5 AD		        lda baseX_lo
   299 3114 18			        clc
   300 3115 65 AB		        adc columnBase
   301 3117 18			        clc
   302 3118 65 B0		        adc bitCounter
   303 311A 85 80		        sta plotX_lo
   304 311C A5 AE		        lda baseX_hi
   305 311E 69 00		        adc #0
   306 3120 85 81		        sta plotX_hi
   307
   308 3122 A5 AF		        lda baseY
   309 3124 18			        clc
   310 3125 65 AA		        adc spriteRow
   311 3127 85 82		        sta plotY
   312
   313 3129 20 5C 31		        jsr erasePoint
   314
   315 312C			eraseskipbit:
   316 312C 46 A9		        lsr spriteMask
   317 312E E6 B0		        inc bitCounter
   318 3130 A5 B0		        lda bitCounter
   319 3132 C9 08		        cmp #8
   320 3134 D0 D6		        bne erasebittest
   321
   322 3136 E6 A6		        inc spritePtr_lo
   323 3138 D0 02		        bne eraseNoCarry
   324 313A E6 A7		        inc spritePtr_hi
   325 313C			eraseNoCarry:
   326 313C A5 AB		        lda columnBase
   327 313E F0 09		        beq eraseSetTo8
   328 3140 A9 00 85 AB		        mva #0 columnBase
   329 3144 E6 AA		        inc spriteRow
   330 3146 4C 4D 31		        jmp eraseAfterToggle
   331 3149			eraseSetTo8:
   332 3149 A9 08 85 AB		        mva #8 columnBase
   333 314D			eraseAfterToggle:
   334
   335 314D E6 AC		        inc byteCount
   336 314F A5 AC		        lda byteCount
   337 3151 C9 18		        cmp #24
   338 3153 D0 A9		        bne eraseloop
   339
   340 				        ; restore spritePtr to its starting value before returning
   341 3155 68			        pla
   342 3156 85 A7		        sta spritePtr_hi
   343 3158 68			        pla
   344 3159 85 A6		        sta spritePtr_lo
   345
   346 315B 60			        rts
   347 				        .endp
