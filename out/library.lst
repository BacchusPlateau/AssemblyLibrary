    57 				; =====================================================================
    58 				; CIO (Central I/O) constants
    59 				; CIO is the Atari OS I/O system. We use it to open graphics mode.
    60 				; Each I/O channel uses an IOCB (I/O Control Block) — a fixed block
    61 				; of memory containing command, device, buffer address, and aux bytes.
    62 				; We use IOCB6 (base address $0360) for graphics.
    63 				; X register = $60 tells CIOV which IOCB to use (IOCB6).
    64 				; =====================================================================
    65 = E456			CIOV    = $E456     ; OS CIO entry point — call jsr CIOV to execute
    66 = 0342			ICCOM   = $0342     ; IOCB6 command register
    67 				                    ;   $03 = OPEN   (open a device)
    68 				                    ;   $0C = CLOSE  (close a device)
    69 = 0344			ICBAL   = $0344     ; IOCB6 buffer address low byte
    70 				                    ;   for OPEN: points to device name string "S:"
    71 = 0345			ICBAH   = $0345     ; IOCB6 buffer address high byte
    72 				                    ;   together with ICBAL forms 16-bit pointer to "S:"
    73 = 034A			ICAX1   = $034A     ; IOCB6 auxiliary byte 1
    74 				                    ;   for OPEN: $0C = read/write access mode
    75 = 034B			ICAX2   = $034B     ; IOCB6 auxiliary byte 2
    76 				                    ;   for OPEN: graphics mode number (8 = GR.8)
    77
    78 				; =====================================================================
    79 				; Screen RAM pointer
    80 				; After CIO opens GR.8, the OS stores the address of screen RAM
    81 				; in SAVMSC (two bytes). $58 = low byte, $59 = high byte.
    82 				; On our 800XL PAL system screen RAM ends up at $B060.
    83 				; =====================================================================
    84 = 0058			SAVMSC  = $58       ; zero page address — low byte of screen RAM address
    85 				                    ; $59 automatically contains the high byte
    86
    87 				; =====================================================================
    88 				; Attract mode constants
    89 				; The Atari OS has an attract mode that kicks in after inactivity
    90 				; to prevent screen burn-in. It does this by desaturating all colors
    91 				; making everything appear as shades of grey/blue.
    92 				; We must continuously reset these in our main loop to keep colors!
    93 				; =====================================================================
    94 = 004D			ATRACT  = $4D       ; attract mode counter — OS increments this each frame
    95 				                    ; when it reaches a threshold attract mode activates
    96 				                    ; we keep writing 0 to prevent it from activating
    97 = 004E			ATRMSK  = $4E       ; attract mode color mask
    98 				                    ; OS ANDs all colors with this value
    99 				                    ; $FE strips hue leaving only luminance (grey/blue)
   100 				                    ; $FF = full color (no masking) — what we want
