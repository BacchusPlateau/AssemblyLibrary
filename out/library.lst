    11 				; graphics variables and constants
    12 = 0080			plotX_lo    = $80       ; low byte of X coordinate (0-319 needs 2 bytes!)
    13 = 0081			plotX_hi    = $81       ; high byte of X coordinate
    14 = 0082			plotY       = $82       ; Y coordinate (0-191, fits in one byte)
    15 = 0083			temp_lo     = $83       ; temporary storage low byte
    16 = 0084			temp_hi     = $84       ; temporary storage high byte
    17 = 0085			scrptr_lo   = $85       ; calculated screen address low byte
    18 = 0086			scrptr_hi   = $86       ; calculated screen address high byte
    19 = 0087			save_lo     = $87       ; saved plotY × 8 low byte
    20 = 0088			save_hi     = $88       ; saved plotY × 8 high byte
    21 = 0089			bitpos      = $89       ; bit position within byte (plotX mod 8) that our pixel lives in
    22 = 008A			bitmask     = $8A       ; save our mask that we will use to turn ONLY our pixel on
