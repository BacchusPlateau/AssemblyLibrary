  1014 				;=========================================================================================
  1015 				; print a string
  1016 				; Assumptions
  1017 				; strptr_lo = low address of the string
  1018 				; strptr_hi = high address of the string
  1019 				;       together we have a 16-bit address of the string
  1020
  1021 				; Y = index of current character to process, starts at 0
  1022 				; example calling code:
  1023 				;       mva #1 csrhinh                  ; hide the cursor
  1024 				;        mva #6 rowcrs                   ; set output row
  1025 				;        mva #10 colcrs                  ; set output column
  1026 				;        
  1027 				;        mva #<string1 strptr_lo         ; low byte of string1 address
  1028 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
  1029 				;        jsr print_string                ; print the string
  1030 				;
  1031 				;========= don't forget you'll need data
  1032 				;       .local string1
  1033 				;        .byte 'HELLO FROM STRING ONE!',0
  1034 				;        .endl
  1035
  1036 				;======================================================================
  1037 345F			        .proc print_string
  1038 345F A0 00		        ldy #0
  1039 3461			loop:
  1040 3461 B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
  1041 3463 C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
  1042 3465 F0 0D		        beq exit                        ; if true, branch to exit
  1043 3467 98			        tya                             ; A = Y
  1044 3468 48			        pha                             ; push A onto the stack
  1045 3469 B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
  1046 346B 20 78 34		        jsr putchar                     ; call putchar to write a character out
  1047 346E 68			        pla                             ; A = pop stack
  1048 346F A8			        tay                             ; Y = A
  1049 3470 C8			        iny                             ; Y = Y + 1
  1050 3471 4C 61 34		        jmp loop                        ; GOTO loop
  1051 3474			exit:
  1052 3474 60			        rts                             ; exit subroutine
  1053 				        .endp
  1054
  1055 3475			stop:
  1056 3475 4C 75 34		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
  1057 				;======================================================================
  1058
  1059 				; print a character
  1060 				; Assumptions
  1061 				; 1. the character is in register A
  1062 				; 2. the character has been converted to ATASCII
  1063 				; 3. before calling, save values of X and Y registers
  1064
  1065 3478			        .proc putchar
  1066 3478 AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
  1067 3479 AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
  1068 347C 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
  1069 347D AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
  1070 3480 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
  1071 3481 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
  1072 3482 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
  1073 				        .endp           ; end of putchar procedure
  1074
  1075 				;========================================================================================
  1076 				;       print a 16-bit decimal
  1077 				;       ON ENTRY: p16_val_lo/p16_val_hi contains the value to print
  1078
  1079 3483			        .proc printBigDecimal
  1080
  1081 				        ; Ten thousands place
  1082 3483 A9 00 85 A5		        mva #0 p16_digit
  1083
  1084 3487			tenthousands:
  1085 				        ; is p16_val >= 10000?
  1086 3487 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1087 3489 C9 27		        cmp #$27                ; 10,000 base 10 is $2710, that's why we're comparing $27 here, the hi byte
  1088 348B 90 1A		        bcc doneTenThousands    ; < 10000, done
  1089 348D D0 06		        bne do_subTenThousands  ; > 10000, subtract
  1090 348F A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1091 3491 C9 10		        cmp #$10                ; now we're comparing the low byte of the literal $2710 hex value
  1092 3493 90 12		        bcc doneTenThousands    ; = exactly check low byte
  1093
  1094 3495			do_subTenThousands:
  1095 				        ; subtract 10000 (16-bit)
  1096 3495 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1097 3497 38			        sec                     ; set the carry
  1098 3498 E9 10		        sbc #$10                ; A -= $10 (we are subtracting the low byte first. looks weird because it's a literal)
  1099 349A 85 A3		        sta p16_val_lo          ; p16_val_lo = A
  1100 349C A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1101 349E E9 27		        sbc #$27                ; A -= $27 (we are subtracting the high byte of $2710 or 10,000 base 10)
  1102 34A0 85 A4		        sta p16_val_hi          ; p16_val_hi = A
  1103 34A2 E6 A5		        inc p16_digit           ; p16_digit++
  1104 34A4 4C 87 34		        jmp tenthousands        ; keep going
  1105
  1106 34A7			doneTenThousands:
  1107 				        ; print the digit
  1108 34A7 A5 A5		        lda p16_digit
  1109 34A9 18			        clc
  1110 34AA 69 30		        adc #offset_to_char
  1111 34AC 20 78 34		        jsr putchar
  1112
  1113 				        ; Thousands
  1114 34AF A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
  1115 34B3			thousands:
  1116 				        ; is p16_val >= 1000?
  1117 34B3 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1118 34B5 C9 03		        cmp #$3                 ; 1000 base 10 is $03E8, that's why we're comparing $3 here, the hi byte
  1119 34B7 90 1A		        bcc doneThousands       ; < 1000, done
  1120 34B9 D0 06		        bne do_subThousands     ; > 1000, subtract
  1121 34BB A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1122 34BD C9 E8		        cmp #$E8                ; now we're comparing the low byte of the literal $03E8 hex value
  1123 34BF 90 12		        bcc doneThousands       ; = exactly check low byte
  1124
  1125 34C1			do_subThousands:
  1126 				        ; subtract 1000 (16-bit)
  1127 34C1 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1128 34C3 38			        sec                     ; set the carry
  1129 34C4 E9 E8		        sbc #$E8                ; A -= $E8 (we are subtracting the low byte first. looks weird because it's a literal)
  1130 34C6 85 A3		        sta p16_val_lo          ; p16_val_lo = A
  1131 34C8 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1132 34CA E9 03		        sbc #$3                 ; A -= $3 (we are subtracting the high byte of $03E8 or 1000 base 10)
  1133 34CC 85 A4		        sta p16_val_hi          ; p16_val_hi = A
  1134 34CE E6 A5		        inc p16_digit           ; p16_digit++
  1135 34D0 4C B3 34		        jmp thousands           ; keep going
  1136
  1137 34D3			doneThousands:
  1138 				        ; print the digit
  1139 34D3 A5 A5		        lda p16_digit
  1140 34D5 18			        clc
  1141 34D6 69 30		        adc #offset_to_char
  1142 34D8 20 78 34		        jsr putchar      
  1143
  1144
  1145 				        ; Hundreds
  1146 34DB A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
  1147 34DF			hundreds:
  1148 				        ; is p16_val >= 100?
  1149 34DF A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1150 34E1 C9 00		        cmp #$0                
  1151 34E3 90 1A		        bcc doneHundreds     
  1152 34E5 D0 06		        bne do_subHundreds     
  1153 34E7 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1154 34E9 C9 64		        cmp #$64              
  1155 34EB 90 12		        bcc doneHundreds        ; = exactly check low byte
  1156
  1157 34ED			do_subHundreds:
  1158 				        ; subtract 100 (16-bit)
  1159 34ED A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1160 34EF 38			        sec                     ; set the carry
  1161 34F0 E9 64		        sbc #$64                ;  (we are subtracting the low byte first. looks weird because it's a literal)
  1162 34F2 85 A3		        sta p16_val_lo          ; p16_val_lo = A
  1163 34F4 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1164 34F6 E9 00		        sbc #$0                 ;  (we are subtracting the high byte of $03E8 or 1000 base 10)
  1165 34F8 85 A4		        sta p16_val_hi          ; p16_val_hi = A
  1166 34FA E6 A5		        inc p16_digit           ; p16_digit++
  1167 34FC 4C DF 34		        jmp hundreds           ; keep going
  1168
  1169 34FF			doneHundreds:
  1170 				        ; print the digit
  1171 34FF A5 A5		        lda p16_digit
  1172 3501 18			        clc
  1173 3502 69 30		        adc #offset_to_char
  1174 3504 20 78 34		        jsr putchar   
  1175
  1176 				        ; Tens
  1177 3507 A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
  1178 350B			tens:
  1179 				        ; is p16_val >= 10?
  1180 350B A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1181 350D C9 00		        cmp #$0                
  1182 350F 90 1A		        bcc doneTens     
  1183 3511 D0 06		        bne do_subTens     
  1184 3513 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1185 3515 C9 0A		        cmp #$0A              
  1186 3517 90 12		        bcc doneTens        ; = exactly check low byte
  1187
  1188 3519			do_subTens:
  1189 				        ; subtract 100 (16-bit)
  1190 3519 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
  1191 351B 38			        sec                     ; set the carry
  1192 351C E9 0A		        sbc #$0A                ;  (we are subtracting the low byte first. looks weird because it's a literal)
  1193 351E 85 A3		        sta p16_val_lo          ; p16_val_lo = A
  1194 3520 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
  1195 3522 E9 00		        sbc #$0                 ;  (we are subtracting the high byte of $03E8 or 1000 base 10)
  1196 3524 85 A4		        sta p16_val_hi          ; p16_val_hi = A
  1197 3526 E6 A5		        inc p16_digit           ; p16_digit++
  1198 3528 4C 0B 35		        jmp tens           ; keep going
  1199
  1200 352B			doneTens:
  1201 				        ; print the digit
  1202 352B A5 A5		        lda p16_digit
  1203 352D 18			        clc
  1204 352E 69 30		        adc #offset_to_char
  1205 3530 20 78 34		        jsr putchar
  1206
  1207 				        ; ones are whatever is left in p16_val_lo
  1208 3533 A5 A3		        lda p16_val_lo
  1209 3535 18			        clc
  1210 3536 69 30		        adc #offset_to_char
  1211 3538 20 78 34		        jsr putchar
  1212
  1213 353B 60			        rts
  1214 				        .endp
  1215
  1216
  1217 				;========================================================================================
  1218 				        ; print both digits in base 10, from left to right
  1219 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
  1220 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
  1221 				        ; Assumtions: A contains the hex value of the number to print
  1222
  1223 353C			        .proc printDecimal
  1224 353C A2 00		        ldx #0
  1225 353E			checkCount:
  1226 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
  1227 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
  1228 353E C9 0A		        cmp #10             ; Does A = 10?
  1229 3540 90 07		        bcc doneCounting    ; branch if carry is cleared
  1230 3542 38			        sec                 ; set carry
  1231 3543 E9 0A		        sbc #10             ; A = A - 10
  1232 3545 E8			        inx                 ; X = X + 1
  1233 3546 4C 3E 35		        jmp checkCount
  1234
  1235 3549			doneCounting:   
  1236 3549 48			        pha                 ; push(A) (push A onto the stack)
  1237 354A 8A			        txa                 ; A = X
  1238 354B 18			        clc
  1239 354C 69 30		        adc #offset_to_char
  1240 354E 20 78 34		        jsr putchar
  1241
  1242 3551 68			        pla                 ; A = pop() (pop the next value off the stack)
  1243 3552 18			        clc 
  1244 3553 69 30		        adc #offset_to_char
  1245 3555 20 78 34		        jsr putchar
  1246 3558 60			        rts
  1247 				        .endp
  1248 				;==================================================================================================
  1249
  1250 				; plot a point (x,y)
  1251 				; Step 1: Find which ROW we're on
  1252 				;        plotY × 40 = how many bytes to skip to reach our row
  1253 				;        (each row is 40 bytes wide)
  1254 				;        2^3 + 2^2
  1255 				; Step 2: Find which BYTE within that row
  1256 				;        plotX ÷ 8 = which byte contains our pixel
  1257 				;        (each byte holds 8 pixels)
  1258 				;
  1259 				; Step 3: Add them together
  1260 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
  1261 				;
  1262 				; Step 4: Add SAVMSC
  1263 				;        SAVMSC + offset = actual address in memory of our byte
  1264 				;
  1265 				; Step 5: Find which BIT within that byte
  1266 				;        7 - (plotX mod 8) = which bit is our pixel
  1267 				;
  1268 				; Step 6: Set that bit
  1269 				;        read the byte
  1270 				;        OR with our bit mask
  1271 				;        write the byte back
  1272 				;
  1273 3559			        .proc plotPoint
  1274
  1275 				        ; see multiplyingYby40.txt for full breakdown with an example!
  1276
  1277 				        ; defeat attract mode on every plot
  1278 3559 A9 00 85 4D		        mva #0    ATRACT
  1279 355D A9 FF 85 4E		        mva #$FF  ATRMSK
  1280
  1281 				        ; Step 1: Find which ROW we're on
  1282 3561 A5 82		        lda plotY
  1283 3563 85 83		        sta temp_lo         ; temp = plotY
  1284 3565 A9 00		        lda #0
  1285 3567 85 84		        sta temp_hi         ; high byte starts at 0
  1286
  1287 				        ; × 2
  1288 3569 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
  1289 356B 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
  1290
  1291 				        ; × 4
  1292 356D 06 83		        asl temp_lo
  1293 356F 26 84		        rol temp_hi
  1294
  1295 				        ; × 8  ← save this!
  1296 3571 06 83		        asl temp_lo
  1297 3573 26 84		        rol temp_hi
  1298 3575 A5 83		        lda temp_lo
  1299 3577 85 87		        sta save_lo
  1300 3579 A5 84		        lda temp_hi
  1301 357B 85 88		        sta save_hi
  1302
  1303 				        ; × 16
  1304 357D 06 83		        asl temp_lo
  1305 357F 26 84		        rol temp_hi
  1306
  1307 				        ; × 32
  1308 3581 06 83		        asl temp_lo
  1309 3583 26 84		        rol temp_hi
  1310
  1311 3585 A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
  1312 3587 18			        clc                 ; clear carry
  1313 3588 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
  1314 358A 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
  1315
  1316 358C A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
  1317 358E 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
  1318 3590 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
  1319 				        ; we now have the offset to our target row in temp_lo and temp_hi
  1320
  1321 				        ; calculate which bit 
  1322 3592 A5 80		        lda plotX_lo
  1323 3594 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
  1324 3596 85 89		        sta bitpos          ; save for Step 5
  1325
  1326 				        ; Step 2: find offset from start of row to our pixel
  1327 				        ; plotX ÷ 8 using 16-bit right shift
  1328 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
  1329 				        ; ON EXIT:  A contains column byte offset (0-39)
  1330 3598 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
  1331 359A 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
  1332
  1333 359C 46 81		        lsr plotX_hi        ; shift again
  1334 359E 66 80		        ror plotX_lo
  1335
  1336 35A0 46 81		        lsr plotX_hi        ; shift again
  1337 35A2 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
  1338
  1339 				        ; Step 3: add results from step 1 and 2 together
  1340 35A4 A5 83		        lda temp_lo
  1341 35A6 18			        clc
  1342 35A7 65 80		        adc plotX_lo
  1343 35A9 85 83		        sta temp_lo
  1344
  1345 35AB A5 84		        lda temp_hi
  1346 35AD 69 00		        adc #0
  1347 35AF 85 84		        sta temp_hi
  1348 				        ; temp now contains total byte offset from SAVMSC
  1349
  1350 				        ; Step 4: Add SAVMSC Base Address
  1351 35B1 A5 83		        lda temp_lo
  1352 35B3 18			        clc
  1353 35B4 65 58		        adc SAVMSC
  1354 35B6 85 85		        sta scrptr_lo
  1355
  1356 35B8 A5 84		        lda temp_hi
  1357 35BA 65 59		        adc SAVMSC+1
  1358 35BC 85 86		        sta scrptr_hi
  1359
  1360 				        ; Step 5: find which bit to turn on
  1361 				        ; algo:  bit position = 7 - (plotX mod 8)
  1362 				        ; Step 5: find which bit to turn on
  1363 35BE A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
  1364 35C0 A6 89		        ldx bitpos          ; X = number of times to shift right
  1365 35C2 F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
  1366 35C4			shift_loop:
  1367 35C4 4A			        lsr                 ; shift A right one position
  1368 35C5 CA			        dex                 ; X = X - 1
  1369 35C6 D0 FC		        bne shift_loop      ; if X != 0 keep shifting
  1370 35C8			done_shift:
  1371 				                            ; A now contains our bit mask
  1372
  1373 				        ; Step 6: turn on our bit!!
  1374 35C8 85 8A		        sta bitmask             ; save mask
  1375 35CA A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
  1376 35CC B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
  1377 35CE 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
  1378 35D0 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
  1379
  1380 35D2 60			        rts
  1381 				        .endp
  1382 				;======================================================================
  1383
