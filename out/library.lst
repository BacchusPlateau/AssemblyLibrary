   260 				; =====================================================================
   261 				; fightAttract
   262 				; Call this every frame in your stop loop to prevent attract mode
   263 				; from desaturating your colors
   264 				; ON ENTRY: nothing
   265 				; ON EXIT:  attract mode defeated for this frame
   266 				;======================================================================
   267 3169			        .proc fightAttract
   268
   269 				        ; defeat attract mode and set colors
   270 3169 A9 00 85 4D		        mva #0    ATRACT
   271 316D A9 FF 85 4E		        mva #$FF  ATRMSK
   272
   273 3171 60			        rts
   274 				        .endp
   275
   276 				; =====================================================================
   277 				; Clear the screen
   278
   279 3172			        .proc clearScreen
   280
   281 				; initialize pointer from SAVMSC
   282 3172 A5 58		        lda SAVMSC
   283 3174 85 85		        sta scrptr_lo
   284 3176 A5 59		        lda SAVMSC+1
   285 3178 85 86		        sta scrptr_hi
   286
   287 				; here we have a nested loop the iner loop will start at 0 and end at 255. 
   288 				; When Y overflows from 255 to 0, bne does NOT branch (falls through)
   289 				; because Y equals zero — exiting the inner loop into the outer loop.
   290
   291 317A A2 1E		        ldx #30             ; X = 30 pages to clear
   292 317C A0 00		        ldy #0              ; Y = byte index within page
   293
   294 317E			clearpage:
   295 317E A9 00		        lda #$00
   296 3180 91 85		        sta (scrptr_lo),y   ; write $00
   297 3182 C8			        iny                 ; next byte
   298 3183 D0 F9		        bne clearpage       ; inner loop — 256 bytes
   299
   300 3185 E6 86		        inc scrptr_hi       ; advance to next page
   301 3187 CA			        dex                 ; X = X - 1
   302 3188 D0 F4		        bne clearpage       ; outer loop — 30 pages
   303
   304 318A 60			        rts
   305 				        .endp
   306
   307
   308 				; =====================================================================
   309 				; Open Graphics Mode 8
   310
   311 318B			        .proc openGR8
   312
   313 				; =====================================================================
   314 				; STEP 1: Close IOCB6
   315 				; Good practice to close before opening — ensures clean state.
   316 				; ON ENTRY: X must contain IOCB number × $10 ($60 for IOCB6)
   317 				; ON ENTRY: ICCOM must contain the command ($0C = CLOSE)
   318 				; ON EXIT:  IOCB6 is closed and ready to be reopened
   319 				; =====================================================================
   320 318B A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
   321 318D A9 0C		        lda #$0C                    ; A = $0C        (CLOSE command)
   322 318F 9D 42 03		        sta ICCOM,x                 ; ICCOM = $0C    (store command in IOCB6)
   323 3192 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute the close)
   324
   325 				; =====================================================================
   326 				; STEP 2: Open Graphics Mode 8
   327 				; Fills in all IOCB6 fields then calls CIOV to execute the open.
   328 				; CIO sets up the display list, allocates screen RAM, configures
   329 				; ANTIC — everything needed for graphics mode automatically.
   330 				; ON ENTRY: nothing required
   331 				; ON EXIT:  GR.8 screen is active, SAVMSC points to screen RAM
   332 				; =====================================================================
   333
   334
   335 				;   Draw yellow pixels on the Atari 800XL in Graphics Mode 8
   336 				;   Uses CIO (Central I/O) to open the graphics mode, then writes
   337 				;   pixel data directly to screen RAM.
   338 				;   GR.8:   320 pixels wide × 192 tall   1 bit per pixel     2 colors
   339 				;   GR.8:   40 bytes × 192 rows = 7,680 bytes
   340 				;   GR.8:   320 pixels ÷ 8 pixels per byte = 40 bytes per row
   341 				;   GR.8 byte:  P P P P P P P P
   342 				;               | | | | | | | |
   343 				;               7 6 5 4 3 2 1 0   (8 pixels, 1 bit each, on or off)
   344
   345 3195 A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
   346 3197 A9 03		        lda #$03                    ; A = $03        (OPEN command)
   347 3199 9D 42 03		        sta ICCOM,x                 ; ICCOM = $03    (store open command)
   348 319C A9 F0		        lda #<scrname               ; A = low byte of "S:" string address
   349 319E 9D 44 03		        sta ICBAL,x                 ; ICBAL = low byte (tell CIO device name location)
   350 31A1 A9 33		        lda #>scrname               ; A = high byte of "S:" string address
   351 31A3 9D 45 03		        sta ICBAH,x                 ; ICBAH = high byte
   352 31A6 A9 08		        lda #$08                    ; A = $08        (graphics mode 8)
   353 31A8 9D 4B 03		        sta ICAX2,x                 ; ICAX2 = $08    (store graphics mode number)
   354 31AB A9 0C		        lda #$0C                    ; A = $0C        (read/write access)
   355 31AD 9D 4A 03		        sta ICAX1,x                 ; ICAX1 = $0C    (store access mode)
   356 31B0 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute open — sets up entire graphics mode!)
   357
   358 				; Step 3: Setup color registers
   359 				; change COLPF1 to change pixel color
   360
   361 31B3 A9 1E 8D C5 02	        mva #$1E  $02C5     ; COLPF1 = yellow (foreground - pixel color)
   362 31B8 A9 00 8D C6 02	        mva #$00  $02C6     ; COLPF2 = black (background)
   363 31BD A9 00 8D C8 02	        mva #$00  $02C8     ; COLBK  = black (border)
   364
   365 31C2 60			        rts
   366 				        .endp
   367
   368 				;=========================================================================================
   369 				; draw a line using Bresenham's algorithm
   370
   371 31C3			        .proc drawLine
   372
   373 				        ; first step, compute:
   374 				        ; dx = x2 - x1    (16-bit subtraction)
   375 				        ; dy = y2 - y1    (8-bit subtraction)
   376
   377 31C3 A5 92		        lda y2          ; A = Y2
   378 31C5 38			        sec             ; set carry
   379 31C6 E5 8F		        sbc y1          ; A = A - Y1
   380 31C8 85 95		        sta dy          ; dy = A
   381
   382 31CA A5 90		        lda x2          ; A = x2 (low byte)
   383 31CC 38			        sec             ; set carry
   384 31CD E5 8D		        sbc x1          ; A = A - X1 (low byte)
   385 31CF 85 93		        sta dx_lo       ; save low byte, but do not re-set carry
   386
   387 31D1 A5 91		        lda x2_hi       ; A = X2 (high byte)
   388 31D3 E5 8E		        sbc x1_hi       ; A = A - X1 (high byte)
   389 31D5 85 94		        sta dx_hi       ; save high byte
   390
   391 				        ; check for vertical line (dx = 0)
   392 31D7 A5 93		        lda dx_lo
   393 31D9 05 94		        ora dx_hi       ; OR low and high bytes together
   394 31DB D0 33		        bne not_vertical ; if result != 0, not vertical
   395
   396 				        ; handle vertical line
   397 				        ; initialize position first!
   398 31DD A5 8D		        lda x1
   399 31DF 85 80		        sta plotX_lo
   400 31E1 A5 8E		        lda x1_hi
   401 31E3 85 81		        sta plotX_hi
   402 31E5 A5 8F		        lda y1
   403 31E7 85 82		        sta plotY
   404
   405 				        ; just loop Y from y1 to y2
   406 31E9			vertical_loop:
   407 31E9 A5 80		        lda plotX_lo    ; save plotX before plotPoint destroys it
   408 31EB 48			        pha
   409 31EC A5 81		        lda plotX_hi
   410 31EE 48			        pha
   411 				        
   412 31EF 20 76 33		        jsr plotPoint
   413 				        
   414 31F2 68			        pla             ; restore plotX
   415 31F3 85 81		        sta plotX_hi
   416 31F5 68			        pla
   417 31F6 85 80		        sta plotX_lo
   418 				        
   419 31F8 E6 82		        inc plotY
   420 31FA A5 82		        lda plotY
   421 31FC C5 92		        cmp y2
   422 31FE D0 E9		        bne vertical_loop
   423 				        
   424 				        ; plot final point
   425 3200 A5 80		        lda plotX_lo
   426 3202 48			        pha
   427 3203 A5 81		        lda plotX_hi
   428 3205 48			        pha
   429 3206 20 76 33		        jsr plotPoint
   430 3209 68			        pla
   431 320A 85 81		        sta plotX_hi
   432 320C 68			        pla
   433 320D 85 80		        sta plotX_lo
   434 				        
   435 320F 60			        rts
   436
   437 3210			not_vertical:
   438 				        ; continue with normal Bresenham...
   439
   440 				        ; initialize current position to start point
   441 3210 A5 8D		        lda x1          ; A = X1
   442 3212 85 80		        sta plotX_lo    ; plotX_lo = A
   443 3214 A5 8E		        lda x1_hi       ; A = X1_hi
   444 3216 85 81		        sta plotX_hi    ; plotX_hi = A
   445 3218 A5 8F		        lda y1          ; A = Y1
   446 321A 85 82		        sta plotY       ; plotY = A
   447
   448 				        ; initialize error to 0
   449 321C A9 00 85 96		        mva #0 err_lo           ; err_lo = 0
   450 3220 A9 00 85 97		        mva #0 err_hi           ; err_hi = 0
   451
   452 3224			lineloop:
   453 				        ; save plotX before plotPoint destroys it
   454 3224 A5 80		        lda plotX_lo
   455 3226 48			        pha
   456 3227 A5 81		        lda plotX_hi
   457 3229 48			        pha
   458
   459 322A 20 76 33		        jsr plotPoint
   460
   461 				        ; restore plotX after plotPoint
   462 322D 68			        pla
   463 322E 85 81		        sta plotX_hi
   464 3230 68			        pla
   465 3231 85 80		        sta plotX_lo
   466
   467 				; add dy to error accumulator (16-bit + 8-bit addition)
   468 3233 A5 96		        lda err_lo              ; A = err_lo
   469 3235 18			        clc                     ; clear carry
   470 3236 65 95		        adc dy                  ; A += dy
   471 3238 85 96		        sta err_lo              ; err_lo = A
   472 323A A5 97		        lda err_hi              ; A = err_hi
   473 323C 69 00		        adc #0                  ; propagate carry trick. if the carry was set it gets added to the high byte
   474 323E 85 97		        sta err_hi              ; err_hi = A
   475
   476 				        ; check if error * 2 >= dx
   477 				        ; compute error + error (16-bit)
   478 3240 A5 96		        lda err_lo              ; A = err_lo
   479 3242 18			        clc                     ; clear carry
   480 3243 65 96		        adc err_lo              ; A += err_lo (err_lo * 2)
   481 3245 85 83		        sta temp_lo             ; temp_lo = A
   482 3247 A5 97		        lda err_hi              ; A = err_hi
   483 3249 65 97		        adc err_hi              ; A += err_hi ((err_hi * 2) + carry)
   484 324B 85 84		        sta temp_hi             ; temp_hi = A
   485
   486 				        ; compare temp (error*2) to dx
   487 				        ; 16-bit comparison: check high byte first, then low byte
   488 324D A5 84		        lda temp_hi     ; A = temp_hi
   489 324F C5 94		        cmp dx_hi       ; Does temp_hi == dx_hi? 
   490 3251 90 17		        bcc skip_y      ; temp_hi < dx_hi, no Y step needed (branch if carry is clear)
   491 3253 D0 06		        bne do_y_step   ; temp_hi > dx_hi, Y step needed (branch if not equal)
   492 3255 A5 83		        lda temp_lo     ; A = temp_lo (high bytes equal, check low bytes (if we got here, high bytes are equal))
   493 3257 C5 93		        cmp dx_lo       ; Does temp_lo == dx_lo?
   494 3259 90 0F		        bcc skip_y      ; temp_lo < dx_lo, no Y step needed
   495
   496 325B			do_y_step:
   497 325B E6 82		        inc plotY       ; y = y + 1
   498
   499 				        ; error = error - dx (16-bit subtraction)
   500 325D A5 96		        lda err_lo      ; A = err_lo
   501 325F 38			        sec             ; set the carry
   502 3260 E5 93		        sbc dx_lo       ; A -= dx_lo
   503 3262 85 96		        sta err_lo      ; err_lo = A
   504 3264 A5 97		        lda err_hi      ; A = err_hi
   505 3266 E5 94		        sbc dx_hi       ; A -= dex_hi
   506 3268 85 97		        sta err_hi      ; err_hi = A
   507
   508 326A			skip_y:
   509 				        ; advance x (16-bit increment)
   510 326A E6 80		        inc plotX_lo            ; plotX_lo++
   511 326C D0 02		        bne lineloop_check      ; if no overflow, check if done 
   512 				                                ; if plotX_lo != 0 JUMP FORWARD to lineloop_check
   513 326E E6 81		        inc plotX_hi            ; handle overflow from low to high byte
   514 				                                ; only reaches here if plotX_lo overflowed to 0
   515
   516 3270			lineloop_check:
   517 				        ; are we done? compare plotX to x2
   518 3270 A5 80		        lda plotX_lo            ; A = plotX_lo
   519 3272 C5 90		        cmp x2                  ; test: A = X2 ?
   520 3274 D0 AE		        bne lineloop            ; not done, keep going
   521 				                                ; if plotX_lo != x2 JUMP BACK to lineloop
   522 3276 A5 81		        lda plotX_hi            ; A = plotX_hi
   523 3278 C5 91		        cmp x2_hi               ; test: A = x2_hi ?
   524 327A D0 A8		        bne lineloop            ; not done, keep going
   525 				                                ; if plotX_hi != x2_hi JUMP BACK to lineloop
   526 				                                ; if both match we fall through - done!
   527
   528 				        
   529
   530 327C 60			        rts
   531 				        .endp
   532
   533
   534 				;=========================================================================================
   535 				; print a string
   536 				; Assumptions
   537 				; strptr_lo = low address of the string
   538 				; strptr_hi = high address of the string
   539 				;       together we have a 16-bit address of the string
   540
   541 				; Y = index of current character to process, starts at 0
   542 				; example calling code:
   543 				;       mva #1 csrhinh                  ; hide the cursor
   544 				;        mva #6 rowcrs                   ; set output row
   545 				;        mva #10 colcrs                  ; set output column
   546 				;        
   547 				;        mva #<string1 strptr_lo         ; low byte of string1 address
   548 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
   549 				;        jsr print_string                ; print the string
   550 				;
   551 				;========= don't forget you'll need data
   552 				;       .local string1
   553 				;        .byte 'HELLO FROM STRING ONE!',0
   554 				;        .endl
   555
   556 				;======================================================================
   557 327D			        .proc print_string
   558 327D A0 00		        ldy #0
   559 327F			loop:
   560 327F B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
   561 3281 C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
   562 3283 F0 0D		        beq exit                        ; if true, branch to exit
   563 3285 98			        tya                             ; A = Y
   564 3286 48			        pha                             ; push A onto the stack
   565 3287 B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
   566 3289 20 96 32		        jsr putchar                     ; call putchar to write a character out
   567 328C 68			        pla                             ; A = pop stack
   568 328D A8			        tay                             ; Y = A
   569 328E C8			        iny                             ; Y = Y + 1
   570 328F 4C 7F 32		        jmp loop                        ; GOTO loop
   571 3292			exit:
   572 3292 60			        rts                             ; exit subroutine
   573 				        .endp
   574
   575 3293			stop:
   576 3293 4C 93 32		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
   577 				;======================================================================
   578
   579 				; print a character
   580 				; Assumptions
   581 				; 1. the character is in register A
   582 				; 2. the character has been converted to ATASCII
   583 				; 3. before calling, save values of X and Y registers
   584
   585 3296			        .proc putchar
   586 3296 AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
   587 3297 AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
   588 329A 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
   589 329B AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
   590 329E 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
   591 329F 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
   592 32A0 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
   593 				        .endp           ; end of putchar procedure
   594
   595 				;========================================================================================
   596 				;       print a 16-bit decimal
   597 				;       ON ENTRY: p16_val_lo/p16_val_hi contains the value to print
   598
   599 32A1			        .proc printBigDecimal
   600
   601 				        ; Ten thousands place
   602 32A1 A9 00 85 A5		        mva #0 p16_digit
   603
   604 32A5			tenthousands:
   605 				        ; is p16_val >= 10000?
   606 32A5 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   607 32A7 C9 27		        cmp #$27                ; 10,000 base 10 is $2710, that's why we're comparing $27 here, the hi byte
   608 32A9 90 1A		        bcc doneTenThousands    ; < 10000, done
   609 32AB D0 06		        bne do_subTenThousands  ; > 10000, subtract
   610 32AD A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   611 32AF C9 10		        cmp #$10                ; now we're comparing the low byte of the literal $2710 hex value
   612 32B1 90 12		        bcc doneTenThousands    ; = exactly check low byte
   613
   614 32B3			do_subTenThousands:
   615 				        ; subtract 10000 (16-bit)
   616 32B3 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   617 32B5 38			        sec                     ; set the carry
   618 32B6 E9 10		        sbc #$10                ; A -= $10 (we are subtracting the low byte first. looks weird because it's a literal)
   619 32B8 85 A3		        sta p16_val_lo          ; p16_val_lo = A
   620 32BA A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   621 32BC E9 27		        sbc #$27                ; A -= $27 (we are subtracting the high byte of $2710 or 10,000 base 10)
   622 32BE 85 A4		        sta p16_val_hi          ; p16_val_hi = A
   623 32C0 E6 A5		        inc p16_digit           ; p16_digit++
   624 32C2 4C A5 32		        jmp tenthousands        ; keep going
   625
   626 32C5			doneTenThousands:
   627 				        ; print the digit
   628 32C5 A5 A5		        lda p16_digit
   629 32C7 18			        clc
   630 32C8 69 30		        adc #offset_to_char
   631 32CA 20 96 32		        jsr putchar
   632
   633 				        ; Thousands
   634 32CD A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
   635 32D1			thousands:
   636 				        ; is p16_val >= 1000?
   637 32D1 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   638 32D3 C9 03		        cmp #$3                 ; 1000 base 10 is $03E8, that's why we're comparing $3 here, the hi byte
   639 32D5 90 1A		        bcc doneThousands       ; < 1000, done
   640 32D7 D0 06		        bne do_subThousands     ; > 1000, subtract
   641 32D9 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   642 32DB C9 E8		        cmp #$E8                ; now we're comparing the low byte of the literal $03E8 hex value
   643 32DD 90 12		        bcc doneThousands       ; = exactly check low byte
   644
   645 32DF			do_subThousands:
   646 				        ; subtract 1000 (16-bit)
   647 32DF A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   648 32E1 38			        sec                     ; set the carry
   649 32E2 E9 E8		        sbc #$E8                ; A -= $E8 (we are subtracting the low byte first. looks weird because it's a literal)
   650 32E4 85 A3		        sta p16_val_lo          ; p16_val_lo = A
   651 32E6 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   652 32E8 E9 03		        sbc #$3                 ; A -= $3 (we are subtracting the high byte of $03E8 or 1000 base 10)
   653 32EA 85 A4		        sta p16_val_hi          ; p16_val_hi = A
   654 32EC E6 A5		        inc p16_digit           ; p16_digit++
   655 32EE 4C D1 32		        jmp thousands           ; keep going
   656
   657 32F1			doneThousands:
   658 				        ; print the digit
   659 32F1 A5 A5		        lda p16_digit
   660 32F3 18			        clc
   661 32F4 69 30		        adc #offset_to_char
   662 32F6 20 96 32		        jsr putchar      
   663
   664
   665 				        ; Hundreds
   666 32F9 A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
   667 32FD			hundreds:
   668 				        ; is p16_val >= 100?
   669 32FD A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   670 32FF C9 00		        cmp #$0                
   671 3301 90 1A		        bcc doneHundreds     
   672 3303 D0 06		        bne do_subHundreds     
   673 3305 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   674 3307 C9 64		        cmp #$64              
   675 3309 90 12		        bcc doneHundreds        ; = exactly check low byte
   676
   677 330B			do_subHundreds:
   678 				        ; subtract 100 (16-bit)
   679 330B A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   680 330D 38			        sec                     ; set the carry
   681 330E E9 64		        sbc #$64                ;  (we are subtracting the low byte first. looks weird because it's a literal)
   682 3310 85 A3		        sta p16_val_lo          ; p16_val_lo = A
   683 3312 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   684 3314 E9 00		        sbc #$0                 ;  (we are subtracting the high byte of $03E8 or 1000 base 10)
   685 3316 85 A4		        sta p16_val_hi          ; p16_val_hi = A
   686 3318 E6 A5		        inc p16_digit           ; p16_digit++
   687 331A 4C FD 32		        jmp hundreds           ; keep going
   688
   689 331D			doneHundreds:
   690 				        ; print the digit
   691 331D A5 A5		        lda p16_digit
   692 331F 18			        clc
   693 3320 69 30		        adc #offset_to_char
   694 3322 20 96 32		        jsr putchar   
   695
   696 				        ; Tens
   697 3325 A9 00 85 A5		        mva #0 p16_digit        ; reset our counter
   698 3329			tens:
   699 				        ; is p16_val >= 10?
   700 3329 A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   701 332B C9 00		        cmp #$0                
   702 332D 90 1A		        bcc doneTens     
   703 332F D0 06		        bne do_subTens     
   704 3331 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   705 3333 C9 0A		        cmp #$0A              
   706 3335 90 12		        bcc doneTens        ; = exactly check low byte
   707
   708 3337			do_subTens:
   709 				        ; subtract 100 (16-bit)
   710 3337 A5 A3		        lda p16_val_lo          ; A = p16_val_lo
   711 3339 38			        sec                     ; set the carry
   712 333A E9 0A		        sbc #$0A                ;  (we are subtracting the low byte first. looks weird because it's a literal)
   713 333C 85 A3		        sta p16_val_lo          ; p16_val_lo = A
   714 333E A5 A4		        lda p16_val_hi          ; A = p16_val_hi
   715 3340 E9 00		        sbc #$0                 ;  (we are subtracting the high byte of $03E8 or 1000 base 10)
   716 3342 85 A4		        sta p16_val_hi          ; p16_val_hi = A
   717 3344 E6 A5		        inc p16_digit           ; p16_digit++
   718 3346 4C 29 33		        jmp tens           ; keep going
   719
   720 3349			doneTens:
   721 				        ; print the digit
   722 3349 A5 A5		        lda p16_digit
   723 334B 18			        clc
   724 334C 69 30		        adc #offset_to_char
   725 334E 20 96 32		        jsr putchar
   726
   727 				        ; ones are whatever is left in p16_val_lo
   728 3351 A5 A3		        lda p16_val_lo
   729 3353 18			        clc
   730 3354 69 30		        adc #offset_to_char
   731 3356 20 96 32		        jsr putchar
   732
   733 3359 60			        rts
   734 				        .endp
   735
   736
   737 				;========================================================================================
   738 				        ; print both digits in base 10, from left to right
   739 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
   740 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
   741 				        ; Assumtions: A contains the hex value of the number to print
   742
   743 335A			        .proc printDecimal
   744 335A A2 00		        ldx #0
   745 335C			checkCount:
   746 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
   747 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
   748 335C C9 0A		        cmp #10             ; Does A = 10?
   749 335E 90 07		        bcc doneCounting    ; branch if carry is cleared
   750 3360 38			        sec                 ; set carry
   751 3361 E9 0A		        sbc #10             ; A = A - 10
   752 3363 E8			        inx                 ; X = X + 1
   753 3364 4C 5C 33		        jmp checkCount
   754
   755 3367			doneCounting:   
   756 3367 48			        pha                 ; push(A) (push A onto the stack)
   757 3368 8A			        txa                 ; A = X
   758 3369 18			        clc
   759 336A 69 30		        adc #offset_to_char
   760 336C 20 96 32		        jsr putchar
   761
   762 336F 68			        pla                 ; A = pop() (pop the next value off the stack)
   763 3370 18			        clc 
   764 3371 69 30		        adc #offset_to_char
   765 3373 20 96 32		        jsr putchar
   766 				        .endp
   767 				;==================================================================================================
   768
   769 				; plot a point (x,y)
   770 				; Step 1: Find which ROW we're on
   771 				;        plotY × 40 = how many bytes to skip to reach our row
   772 				;        (each row is 40 bytes wide)
   773 				;        2^3 + 2^2
   774 				; Step 2: Find which BYTE within that row
   775 				;        plotX ÷ 8 = which byte contains our pixel
   776 				;        (each byte holds 8 pixels)
   777 				;
   778 				; Step 3: Add them together
   779 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
   780 				;
   781 				; Step 4: Add SAVMSC
   782 				;        SAVMSC + offset = actual address in memory of our byte
   783 				;
   784 				; Step 5: Find which BIT within that byte
   785 				;        7 - (plotX mod 8) = which bit is our pixel
   786 				;
   787 				; Step 6: Set that bit
   788 				;        read the byte
   789 				;        OR with our bit mask
   790 				;        write the byte back
   791 				;
   792 3376			        .proc plotPoint
   793
   794 				        ; see multiplyingYby40.txt for full breakdown with an example!
   795
   796 				        ; defeat attract mode on every plot
   797 3376 A9 00 85 4D		        mva #0    ATRACT
   798 337A A9 FF 85 4E		        mva #$FF  ATRMSK
   799
   800 				        ; Step 1: Find which ROW we're on
   801 337E A5 82		        lda plotY
   802 3380 85 83		        sta temp_lo         ; temp = plotY
   803 3382 A9 00		        lda #0
   804 3384 85 84		        sta temp_hi         ; high byte starts at 0
   805
   806 				        ; × 2
   807 3386 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
   808 3388 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
   809
   810 				        ; × 4
   811 338A 06 83		        asl temp_lo
   812 338C 26 84		        rol temp_hi
   813
   814 				        ; × 8  ← save this!
   815 338E 06 83		        asl temp_lo
   816 3390 26 84		        rol temp_hi
   817 3392 A5 83		        lda temp_lo
   818 3394 85 87		        sta save_lo
   819 3396 A5 84		        lda temp_hi
   820 3398 85 88		        sta save_hi
   821
   822 				        ; × 16
   823 339A 06 83		        asl temp_lo
   824 339C 26 84		        rol temp_hi
   825
   826 				        ; × 32
   827 339E 06 83		        asl temp_lo
   828 33A0 26 84		        rol temp_hi
   829
   830 33A2 A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
   831 33A4 18			        clc                 ; clear carry
   832 33A5 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
   833 33A7 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
   834
   835 33A9 A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
   836 33AB 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
   837 33AD 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
   838 				        ; we now have the offset to our target row in temp_lo and temp_hi
   839
   840 				        ; calculate which bit 
   841 33AF A5 80		        lda plotX_lo
   842 33B1 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
   843 33B3 85 89		        sta bitpos          ; save for Step 5
   844
   845 				        ; Step 2: find offset from start of row to our pixel
   846 				        ; plotX ÷ 8 using 16-bit right shift
   847 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
   848 				        ; ON EXIT:  A contains column byte offset (0-39)
   849 33B5 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
   850 33B7 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
   851
   852 33B9 46 81		        lsr plotX_hi        ; shift again
   853 33BB 66 80		        ror plotX_lo
   854
   855 33BD 46 81		        lsr plotX_hi        ; shift again
   856 33BF 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
   857
   858 				        ; Step 3: add results from step 1 and 2 together
   859 33C1 A5 83		        lda temp_lo
   860 33C3 18			        clc
   861 33C4 65 80		        adc plotX_lo
   862 33C6 85 83		        sta temp_lo
   863
   864 33C8 A5 84		        lda temp_hi
   865 33CA 69 00		        adc #0
   866 33CC 85 84		        sta temp_hi
   867 				        ; temp now contains total byte offset from SAVMSC
   868
   869 				        ; Step 4: Add SAVMSC Base Address
   870 33CE A5 83		        lda temp_lo
   871 33D0 18			        clc
   872 33D1 65 58		        adc SAVMSC
   873 33D3 85 85		        sta scrptr_lo
   874
   875 33D5 A5 84		        lda temp_hi
   876 33D7 65 59		        adc SAVMSC+1
   877 33D9 85 86		        sta scrptr_hi
   878
   879 				        ; Step 5: find which bit to turn on
   880 				        ; algo:  bit position = 7 - (plotX mod 8)
   881 				        ; Step 5: find which bit to turn on
   882 33DB A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
   883 33DD A6 89		        ldx bitpos          ; X = number of times to shift right
   884 33DF F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
   885 33E1			shift_loop:
   886 33E1 4A			        lsr                 ; shift A right one position
   887 33E2 CA			        dex                 ; X = X - 1
   888 33E3 D0 FC		        bne shift_loop      ; if X != 0 keep shifting
   889 33E5			done_shift:
   890 				                            ; A now contains our bit mask
   891
   892 				        ; Step 6: turn on our bit!!
   893 33E5 85 8A		        sta bitmask             ; save mask
   894 33E7 A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
   895 33E9 B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
   896 33EB 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
   897 33ED 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
   898
   899 33EF 60			        rts
   900 				        .endp
