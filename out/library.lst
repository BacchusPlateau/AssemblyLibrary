    18 				;=========================================================================================
    19 				; draw a sprite
    20 				; Assumptions: caller sets spritePtr_lo/spritePtr_hi 
    21 				;       (and presumably baseX_lo/baseX_hi/baseY) before calling
    22 				;
    23 				; spritePtr = address of shipSprite
    24 				; row = 0
    25 				; for byteIndex = 0 to 23:
    26 				;    spriteByte = read byte at spritePtr, advance spritePtr
    27 				;    columnBase = (byteIndex mod 2) * 8        ; 0 for even bytes, 8 for odd bytes
    28 				;    mask = %10000000
    29 				;    for bitCounter = 0 to 7:
    30 				;        if spriteByte AND mask != 0:
    31 				;            plotX = baseX + columnBase + bitCounter
    32 				;            plotY = baseY + row
    33 				;            plotPoint
    34 				;        mask = mask >> 1
    35 				;    if byteIndex is odd:
    36 				;        row = row + 1
    37 3018			.proc drawSprite
    38
    39 3018 A5 A6		        lda spritePtr_lo
    40 301A 48			        pha
    41 301B A5 A7		        lda spritePtr_hi
    42 301D 48			        pha
    43
    44 301E A9 00 85 AA		        mva #0 spriteRow
    45 3022 A9 00 85 AC		        mva #0 byteCount
    46 3026 A9 00 85 AB		        mva #0 columnBase
    47
    48 302A			spriteloop:
    49 302A A0 00		        ldy #0
    50 302C B1 A6		        lda (spritePtr_lo),y
    51 302E 85 A8		        sta spriteByte
    52
    53 3030 A9 80 85 A9		        mva #%10000000 spriteMask
    54 3034 A9 00 85 B0		        mva #0 bitCounter
    55
    56 3038			bittest:
    57 3038 A5 A8		        lda spriteByte
    58 303A 25 A9		        and spriteMask
    59 303C F0 1A		        beq skipbit
    60
    61 303E A5 AD		        lda baseX_lo
    62 3040 18			        clc
    63 3041 65 AB		        adc columnBase
    64 3043 18			        clc
    65 3044 65 B0		        adc bitCounter
    66 3046 85 80		        sta plotX_lo
    67 3048 A5 AE		        lda baseX_hi
    68 304A 69 00		        adc #0
    69 304C 85 81		        sta plotX_hi
    70
    71 304E A5 AF		        lda baseY
    72 3050 18			        clc
    73 3051 65 AA		        adc spriteRow
    74 3053 85 82		        sta plotY
    75
    76 3055 20 59 35		        jsr plotPoint
    77
    78 3058			skipbit:
    79 3058 46 A9		        lsr spriteMask
    80 305A E6 B0		        inc bitCounter
    81 305C A5 B0		        lda bitCounter
    82 305E C9 08		        cmp #8
    83 3060 D0 D6		        bne bittest
    84
    85 3062 E6 A6		        inc spritePtr_lo
    86 3064 D0 02		        bne noCarry
    87 3066 E6 A7		        inc spritePtr_hi
    88 3068			noCarry:
    89 3068 A5 AB		        lda columnBase
    90 306A F0 09		        beq setTo8
    91 306C A9 00 85 AB		        mva #0 columnBase
    92 3070 E6 AA		        inc spriteRow
    93 3072 4C 79 30		        jmp afterToggle
    94 3075			setTo8:
    95 3075 A9 08 85 AB		        mva #8 columnBase
    96 3079			afterToggle:
    97
    98 3079 E6 AC		        inc byteCount
    99 307B A5 AC		        lda byteCount
   100 307D C9 18		        cmp #24
   101 307F D0 A9		        bne spriteloop
   102
   103 3081 68			        pla
   104 3082 85 A7		        sta spritePtr_hi
   105 3084 68			        pla
   106 3085 85 A6		        sta spritePtr_lo
   107
   108 3087 60			        rts
