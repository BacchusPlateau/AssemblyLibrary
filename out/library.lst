Source: routines.asm
     1 				; routines.asm
     2 				        org $3000               ; routines live at $3000
     3
     4 				; print a string
     5 				; Assumptions
     6 				; strptr_lo = low address of the string
     7 				; strptr_hi = high address of the string
     8 				;       together we have a 16-bit address of the string
     9
    10 				; Y = index of current character to process, starts at 0
    11 				; example calling code:
    12 				;       mva #1 csrhinh                  ; hide the cursor
    13 				;        mva #6 rowcrs                   ; set output row
    14 				;        mva #10 colcrs                  ; set output column
    15 				;        
    16 				;        mva #<string1 strptr_lo         ; low byte of string1 address
    17 				;        mva #>string1 strptr_hi         ; high byte o f string1 address
    18 				;        jsr print_string                ; print the string
    19 				;
    20 				;========= don't forget you'll need data
    21 				;       .local string1
    22 				;        .byte 'HELLO FROM STRING ONE!',0
    23 				;        .endl
    24
    25 				;======================================================================
    26 				        .proc print_string
    27 FFFF> 3000-30BB> A0 00	        ldy #0
    28 3002			loop:
    29 3002 B1 8B		        lda (strptr_lo),y               ; with an offset of Y bytes, grab the byte at the 16-bit address
    30 3004 C9 00		        cmp #0                          ; test if we found the 0 string terminator: A == 0?   
    31 3006 F0 0D		        beq exit                        ; if true, branch to exit
    32 3008 98			        tya                             ; A = Y
    33 3009 48			        pha                             ; push A onto the stack
    34 300A B1 8B		        lda (strptr_lo),y               ; re-fetch current byte of string
    35 300C 20 19 30		        jsr putchar                     ; call putchar to write a character out
    36 300F 68			        pla                             ; A = pop stack
    37 3010 A8			        tay                             ; Y = A
    38 3011 C8			        iny                             ; Y = Y + 1
    39 3012 4C 02 30		        jmp loop                        ; GOTO loop
    40 3015			exit:
    41 3015 60			        rts                             ; exit subroutine
    42 				        .endp
    43
    44 3016			stop:
    45 3016 4C 16 30		        jmp stop                        ; GOTO stop                   (infinite loop = program halts here)
    46 				;======================================================================
    47
    48 				; print a character
    49 				; Assumptions
    50 				; 1. the character is in register A
    51 				; 2. the character has been converted to ATASCII
    52 				; 3. before calling, save values of X and Y registers
    53
    54 3019			        .proc putchar
    55 3019 AA			        tax             ; X = A                       (save character from A into X because A is about to be clobbered)
    56 301A AD 47 03		        lda putchar_ptr+1 ; A = memory[$347]          (load high byte of OS print routine address)
    57 301D 48			        pha             ; push A onto stack            (high byte on stack, will be popped second by rts)
    58 301E AD 46 03		        lda putchar_ptr ; A = memory[$346]            (load low byte of OS print routine address)
    59 3021 48			        pha             ; push A onto stack            (low byte on stack, will be popped first by rts)
    60 3022 8A			        txa             ; A = X                       (restore original character back into A because OS print routine expects character value in A)
    61 3023 60			        rts             ; RETURN                      (pops OS address from stack and jumps there, OS prints character in A, then returns to main)
    62 				        .endp           ; end of putchar procedure
    63
    64 				;========================================================================================
    65 				        ; print both digits in base 10, from left to right
    66 				        ; strategy is to continue subracting 10 from our hex value until it is less than 10
    67 				        ; once we are there we now have the "tens digit" in X and the "ones digit" in A
    68 				        ; Assumtions: A contains the hex value of the number to print
    69
    70 3024			        .proc printDecimal
    71 3024 A2 00		        ldx #0
    72 3026			checkCount:
    73 				        ; if A < 10   → carry = 0  → bcc branches   (carry CLEAR)
    74 				        ; if A >= 10  → carry = 1  → bcs branches   (carry SET)
    75 3026 C9 0A		        cmp #10             ; Does A = 10?
    76 3028 90 06		        bcc doneCounting    ; branch if carry is cleared
    77 302A 38			        sec                 ; set carry
    78 302B E9 0A		        sbc #10             ; A = A - 10
    79 302D E8			        inx                 ; X = X + 1
    80 302E D0 F6		        bne checkCount
    81
    82 3030			doneCounting:   
    83 3030 48			        pha                 ; push(A) (push A onto the stack)
    84 3031 8A			        txa                 ; A = X
    85 3032 18			        clc
    86 3033 69 30		        adc #offset_to_char
    87 3035 20 19 30		        jsr putchar
    88
    89 3038 68			        pla                 ; A = pop() (pop the next value off the stack)
    90 3039 18			        clc 
    91 303A 69 30		        adc #offset_to_char
    92 303C 20 19 30		        jsr putchar
    93 				        .endp
    94 				;==================================================================================================
    95
    96 				; plot a point (x,y)
    97 				; Step 1: Find which ROW we're on
    98 				;        plotY × 40 = how many bytes to skip to reach our row
    99 				;        (each row is 40 bytes wide)
   100 				;        2^3 + 2^2
   101 				; Step 2: Find which BYTE within that row
   102 				;        plotX ÷ 8 = which byte contains our pixel
   103 				;        (each byte holds 8 pixels)
   104 				;
   105 				; Step 3: Add them together
   106 				;        (plotY × 40) + (plotX ÷ 8) = total byte offset from start of screen RAM
   107 				;
   108 				; Step 4: Add SAVMSC
   109 				;        SAVMSC + offset = actual address in memory of our byte
   110 				;
   111 				; Step 5: Find which BIT within that byte
   112 				;        7 - (plotX mod 8) = which bit is our pixel
   113 				;
   114 				; Step 6: Set that bit
   115 				;        read the byte
   116 				;        OR with our bit mask
   117 				;        write the byte back
   118 				;
   119 303F			        .proc plotPoint
   120
   121 				        ; see multiplyingYby40.txt for full breakdown with an example!
   122
   123 				        ; defeat attract mode on every plot
   124 303F A9 00 85 4D		        mva #0    ATRACT
   125 3043 A9 FF 85 4E		        mva #$FF  ATRMSK
   126
   127 				        ; Step 1: Find which ROW we're on
   128 3047 A5 82		        lda plotY
   129 3049 85 83		        sta temp_lo         ; temp = plotY
   130 304B A9 00		        lda #0
   131 304D 85 84		        sta temp_hi         ; high byte starts at 0
   132
   133 				        ; × 2
   134 304F 06 83		        asl temp_lo         ; shift temp_lo to the left one bit
   135 3051 26 84		        rol temp_hi         ; shift temp_hi to the left one bit and include the carry 
   136
   137 				        ; × 4
   138 3053 06 83		        asl temp_lo
   139 3055 26 84		        rol temp_hi
   140
   141 				        ; × 8  ← save this!
   142 3057 06 83		        asl temp_lo
   143 3059 26 84		        rol temp_hi
   144 305B A5 83		        lda temp_lo
   145 305D 85 87		        sta save_lo
   146 305F A5 84		        lda temp_hi
   147 3061 85 88		        sta save_hi
   148
   149 				        ; × 16
   150 3063 06 83		        asl temp_lo
   151 3065 26 84		        rol temp_hi
   152
   153 				        ; × 32
   154 3067 06 83		        asl temp_lo
   155 3069 26 84		        rol temp_hi
   156
   157 306B A5 83		        lda temp_lo         ; A = temp_lo    (low byte of plotY × 32)
   158 306D 18			        clc                 ; clear carry
   159 306E 65 87		        adc save_lo         ; A = temp_lo + save_lo  (add plotY × 8)
   160 3070 85 83		        sta temp_lo         ; temp_lo = low byte of plotY × 40
   161
   162 3072 A5 84		        lda temp_hi         ; A = temp_hi    (high byte of plotY × 32)
   163 3074 65 88		        adc save_hi         ; A = temp_hi + save_hi + carry  (add high bytes)
   164 3076 85 84		        sta temp_hi         ; temp_hi = high byte of plotY × 40
   165 				        ; we now have the offset to our target row in temp_lo and temp_hi
   166
   167 				        ; calculate which bit 
   168 3078 A5 80		        lda plotX_lo
   169 307A 29 07		        and #%00000111      ; mask bottom 3 bits = plotX mod 8
   170 307C 85 89		        sta bitpos          ; save for Step 5
   171
   172 				        ; Step 2: find offset from start of row to our pixel
   173 				        ; plotX ÷ 8 using 16-bit right shift
   174 				        ; ON ENTRY: plotX_hi/plotX_lo contains X coordinate (0-319)
   175 				        ; ON EXIT:  A contains column byte offset (0-39)
   176 307E 46 81		        lsr plotX_hi        ; shift high byte right, bit 0 → carry
   177 3080 66 80		        ror plotX_lo        ; carry → bit 7 of low byte, bit 0 → carry
   178
   179 3082 46 81		        lsr plotX_hi        ; shift again
   180 3084 66 80		        ror plotX_lo
   181
   182 3086 46 81		        lsr plotX_hi        ; shift again
   183 3088 66 80		        ror plotX_lo        ; plotX_lo now contains plotX ÷ 8
   184
   185 				        ; Step 3: add results from step 1 and 2 together
   186 308A A5 83		        lda temp_lo
   187 308C 18			        clc
   188 308D 65 80		        adc plotX_lo
   189 308F 85 83		        sta temp_lo
   190
   191 3091 A5 84		        lda temp_hi
   192 3093 69 00		        adc #0
   193 3095 85 84		        sta temp_hi
   194 				        ; temp now contains total byte offset from SAVMSC
   195
   196 				        ; Step 4: Add SAVMSC Base Address
   197 3097 A5 83		        lda temp_lo
   198 3099 18			        clc
   199 309A 65 58		        adc SAVMSC
   200 309C 85 85		        sta scrptr_lo
   201
   202 309E A5 84		        lda temp_hi
   203 30A0 65 59		        adc SAVMSC+1
   204 30A2 85 86		        sta scrptr_hi
   205
   206 				        ; Step 5: find which bit to turn on
   207 				        ; algo:  bit position = 7 - (plotX mod 8)
   208 				        ; Step 5: find which bit to turn on
   209 30A4 A9 80		        lda #$80            ; A = %10000000  (start with bit 7)
   210 30A6 A6 89		        ldx bitpos          ; X = number of times to shift right
   211 30A8 F0 04		        beq done_shift      ; if bitpos = 0 no shifting needed!
   212 30AA			shift_loop:
   213 30AA 4A			        lsr                 ; shift A right one position
   214 30AB CA			        dex                 ; X = X - 1
   215 30AC D0 FC		        bne shift_loop      ; if X != 0 keep shifting
   216 30AE			done_shift:
   217 				                            ; A now contains our bit mask
   218
   219 				        ; Step 6: turn on our bit!!
   220 30AE 85 8A		        sta bitmask             ; save mask
   221 30B0 A0 00		        ldy #0                  ; Y = 0 for indirect indexed addressing
   222 30B2 B1 85		        lda (scrptr_lo),y       ; read current byte from screen RAM
   223 30B4 05 8A		        ora bitmask             ; OR with our bit mask (sets our pixel bit)
   224 30B6 91 85		        sta (scrptr_lo),y       ; write modified byte back to screen RAM
   225
   226 30B8 60			        rts
   227 				        .endp
