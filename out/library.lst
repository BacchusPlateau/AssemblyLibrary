   349
   350 				;=========================================================================
   351 				; erasePoint
   352 				; Clears (turns OFF) a single pixel in GR.8 screen RAM, at the position
   353 				; given by plotX_lo/plotX_hi and plotY. This is the exact mirror of
   354 				; plotPoint — same six steps to locate the byte and bit — except the
   355 				; final step CLEARS the bit instead of SETTING it.
   356 				; ON ENTRY: plotX_lo/plotX_hi/plotY contain the pixel coordinates
   357 				; ON EXIT:  the corresponding screen RAM bit is cleared to 0 (background)
   358 				;           NOTE: just like plotPoint, this destroys plotX_lo/plotX_hi!
   359 				;=========================================================================
   360 315C			        .proc erasePoint
   361
   362 				        ; defeat attract mode on every erase, same as plotPoint does
   363 315C A9 00 85 4D		        mva #0    ATRACT
   364 3160 A9 FF 85 4E		        mva #$FF  ATRMSK
   365
   366 				        ; Step 1: Find which ROW we're on  (plotY × 40)
   367 3164 A5 82		        lda plotY
   368 3166 85 83		        sta temp_lo
   369 3168 A9 00		        lda #0
   370 316A 85 84		        sta temp_hi
   371
   372 316C 06 83		        asl temp_lo
   373 316E 26 84		        rol temp_hi
   374
   375 3170 06 83		        asl temp_lo
   376 3172 26 84		        rol temp_hi
   377
   378 3174 06 83		        asl temp_lo
   379 3176 26 84		        rol temp_hi
   380 3178 A5 83		        lda temp_lo
   381 317A 85 87		        sta save_lo
   382 317C A5 84		        lda temp_hi
   383 317E 85 88		        sta save_hi
   384
   385 3180 06 83		        asl temp_lo
   386 3182 26 84		        rol temp_hi
   387
   388 3184 06 83		        asl temp_lo
   389 3186 26 84		        rol temp_hi
   390
   391 3188 A5 83		        lda temp_lo
   392 318A 18			        clc
   393 318B 65 87		        adc save_lo
   394 318D 85 83		        sta temp_lo
   395
   396 318F A5 84		        lda temp_hi
   397 3191 65 88		        adc save_hi
   398 3193 85 84		        sta temp_hi
   399
   400 				        ; calculate which bit (plotX mod 8)
   401 3195 A5 80		        lda plotX_lo
   402 3197 29 07		        and #%00000111
   403 3199 85 89		        sta bitpos
   404
   405 				        ; Step 2: plotX ÷ 8 using 16-bit right shift
   406 319B 46 81		        lsr plotX_hi
   407 319D 66 80		        ror plotX_lo
   408
   409 319F 46 81		        lsr plotX_hi
   410 31A1 66 80		        ror plotX_lo
   411
   412 31A3 46 81		        lsr plotX_hi
   413 31A5 66 80		        ror plotX_lo
   414
   415 				        ; Step 3: add row offset + column offset
   416 31A7 A5 83		        lda temp_lo
   417 31A9 18			        clc
   418 31AA 65 80		        adc plotX_lo
   419 31AC 85 83		        sta temp_lo
   420
   421 31AE A5 84		        lda temp_hi
   422 31B0 69 00		        adc #0
   423 31B2 85 84		        sta temp_hi
   424
   425 				        ; Step 4: Add SAVMSC Base Address
   426 31B4 A5 83		        lda temp_lo
   427 31B6 18			        clc
   428 31B7 65 58		        adc SAVMSC
   429 31B9 85 85		        sta scrptr_lo
   430
   431 31BB A5 84		        lda temp_hi
   432 31BD 65 59		        adc SAVMSC+1
   433 31BF 85 86		        sta scrptr_hi
   434
   435 				        ; Step 5: find which bit to turn off
   436 31C1 A9 80		        lda #$80
   437 31C3 A6 89		        ldx bitpos
   438 31C5 F0 04		        beq done_shift
   439 31C7			shift_loop_erase:
   440 31C7 4A			        lsr
   441 31C8 CA			        dex
   442 31C9 D0 FC		        bne shift_loop_erase
   443 31CB			done_shift:
   444
   445 				        ; Step 6: turn OFF our bit (the only step that differs from
   446 				        ; plotPoint!) — invert the mask so every bit is 1 EXCEPT
   447 				        ; our target pixel, then AND it against the screen byte to
   448 				        ; clear just that one bit while leaving all others untouched
   449 31CB 49 FF		        eor #$FF                ; invert: our bit is now 0, rest are 1
   450 31CD 85 8A		        sta bitmask              ; save the inverted mask
   451 31CF A0 00		        ldy #0
   452 31D1 B1 85		        lda (scrptr_lo),y        ; read current byte from screen RAM
   453 31D3 25 8A		        and bitmask               ; AND clears just our bit
   454 31D5 91 85		        sta (scrptr_lo),y        ; write modified byte back
   455
   456 31D7 60			        rts
   457 				        .endp
   458
   459 				;=========================================================================
   460 				; waitFrames
   461 				; Pauses execution for a given number of vertical blank frames.
   462 				; On PAL the frame counter at $14 increments roughly 50 times per
   463 				; second; on NTSC it's roughly 60 times per second. The OS updates
   464 				; this counter automatically during every VBI, completely independent
   465 				; of our code — so we just watch it change.
   466 				; ON ENTRY: X contains the number of frames to wait
   467 				; ON EXIT:  approximately X/50 seconds (PAL) have elapsed
   468 				;=========================================================================
   469 31D8			        .proc waitFrames
   470
   471 31D8			waitOneFrame:
   472 31D8 A5 14		        lda $14                 ; A = current frame counter value
   473 31DA			holdFrame:
   474 31DA C5 14		        cmp $14                 ; has the counter changed yet?
   475 31DC F0 FC		        beq holdFrame           ; no — keep checking (busy-wait)
   476 				                                ; yes — one full frame has now elapsed
   477
   478 31DE CA			        dex                     ; X = X - 1 (one frame counted off)
   479 31DF D0 F7		        bne waitOneFrame        ; more frames to wait? go again
   480
   481 31E1 60			        rts
   482 				        .endp
   483
   484
   485 				;=========================================================================================
   486 				; draw a circle using Bresenham's circle algorithm
   487 				; ON ENTRY: cx/cx_hi = center X, cy = center Y, radius = radius
   488 				; ON EXIT:  circle drawn on screen
   489
   490 31E2			        .proc drawCircle
   491
   492 				        ; initialize error term: cerr = 1 - radius
   493 31E2 A9 01		        lda #1
   494 31E4 38			        sec
   495 31E5 E5 9E		        sbc radius
   496 31E7 85 A1		        sta cerr_lo
   497 31E9 A9 00		        lda #0
   498 31EB E9 00		        sbc #0
   499 31ED 85 A2		        sta cerr_hi
   500
   501 				        ; initialize offsets
   502 31EF A9 00 85 9F		        mva #0  circX       ; circX = 0
   503 31F3 A5 9E		        lda radius
   504 31F5 85 A0		        sta circY           ; circY = radius
   505
   506 31F7			circleloop:
   507
   508 				        ; plot point 1: (cx + circX, cy + circY)
   509 31F7 A5 9B		        lda cx
   510 31F9 18			        clc
   511 31FA 65 9F		        adc circX
   512 31FC 85 80		        sta plotX_lo
   513 31FE A5 9C		        lda cx_hi
   514 3200 69 00		        adc #0
   515 3202 85 81		        sta plotX_hi
   516 3204 A5 9D		        lda cy
   517 3206 18			        clc
   518 3207 65 A0		        adc circY
   519 3209 85 82		        sta plotY
   520
   521 320B A5 80		        lda plotX_lo
   522 320D 48			        pha
   523 320E A5 81		        lda plotX_hi
   524 3210 48			        pha
   525 3211 20 59 35		        jsr plotPoint
   526 3214 68			        pla
   527 3215 85 81		        sta plotX_hi
   528 3217 68			        pla
   529 3218 85 80		        sta plotX_lo
   530
   531 				        ; plot point 2: (cx - circX, cy + circY)
   532 321A A5 9B		        lda cx
   533 321C 38			        sec
   534 321D E5 9F		        sbc circX
   535 321F 85 80		        sta plotX_lo
   536 3221 A5 9C		        lda cx_hi
   537 3223 E9 00		        sbc #0
   538 3225 85 81		        sta plotX_hi
   539 3227 A5 9D		        lda cy
   540 3229 18			        clc
   541 322A 65 A0		        adc circY
   542 322C 85 82		        sta plotY
   543
   544 322E A5 80		        lda plotX_lo
   545 3230 48			        pha
   546 3231 A5 81		        lda plotX_hi
   547 3233 48			        pha
   548 3234 20 59 35		        jsr plotPoint
   549 3237 68			        pla
   550 3238 85 81		        sta plotX_hi
   551 323A 68			        pla
   552 323B 85 80		        sta plotX_lo
   553
   554 				        ; plot point 3: (cx + circX, cy - circY)
   555 323D A5 9B		        lda cx
   556 323F 18			        clc
   557 3240 65 9F		        adc circX
   558 3242 85 80		        sta plotX_lo
   559 3244 A5 9C		        lda cx_hi
   560 3246 69 00		        adc #0
   561 3248 85 81		        sta plotX_hi
   562 324A A5 9D		        lda cy
   563 324C 38			        sec
   564 324D E5 A0		        sbc circY
   565 324F 85 82		        sta plotY
   566
   567 3251 A5 80		        lda plotX_lo
   568 3253 48			        pha
   569 3254 A5 81		        lda plotX_hi
   570 3256 48			        pha
   571 3257 20 59 35		        jsr plotPoint
   572 325A 68			        pla
   573 325B 85 81		        sta plotX_hi
   574 325D 68			        pla
   575 325E 85 80		        sta plotX_lo
   576
   577 				        ; plot point 4: (cx - circX, cy - circY)
   578 3260 A5 9B		        lda cx
   579 3262 38			        sec
   580 3263 E5 9F		        sbc circX
   581 3265 85 80		        sta plotX_lo
   582 3267 A5 9C		        lda cx_hi
   583 3269 E9 00		        sbc #0
   584 326B 85 81		        sta plotX_hi
   585 326D A5 9D		        lda cy
   586 326F 38			        sec
   587 3270 E5 A0		        sbc circY
   588 3272 85 82		        sta plotY
   589
   590 3274 A5 80		        lda plotX_lo
   591 3276 48			        pha
   592 3277 A5 81		        lda plotX_hi
   593 3279 48			        pha
   594 327A 20 59 35		        jsr plotPoint
   595 327D 68			        pla
   596 327E 85 81		        sta plotX_hi
   597 3280 68			        pla
   598 3281 85 80		        sta plotX_lo
   599
   600 				        ; plot point 5: (cx + circY, cy + circX)
   601 3283 A5 9B		        lda cx
   602 3285 18			        clc
   603 3286 65 A0		        adc circY
   604 3288 85 80		        sta plotX_lo
   605 328A A5 9C		        lda cx_hi
   606 328C 69 00		        adc #0
   607 328E 85 81		        sta plotX_hi
   608 3290 A5 9D		        lda cy
   609 3292 18			        clc
   610 3293 65 9F		        adc circX
   611 3295 85 82		        sta plotY
   612
   613 3297 A5 80		        lda plotX_lo
   614 3299 48			        pha
   615 329A A5 81		        lda plotX_hi
   616 329C 48			        pha
   617 329D 20 59 35		        jsr plotPoint
   618 32A0 68			        pla
   619 32A1 85 81		        sta plotX_hi
   620 32A3 68			        pla
   621 32A4 85 80		        sta plotX_lo
   622
   623 				        ; plot point 6: (cx - circY, cy + circX)
   624 32A6 A5 9B		        lda cx
   625 32A8 38			        sec
   626 32A9 E5 A0		        sbc circY
   627 32AB 85 80		        sta plotX_lo
   628 32AD A5 9C		        lda cx_hi
   629 32AF E9 00		        sbc #0
   630 32B1 85 81		        sta plotX_hi
   631 32B3 A5 9D		        lda cy
   632 32B5 18			        clc
   633 32B6 65 9F		        adc circX
   634 32B8 85 82		        sta plotY
   635
   636 32BA A5 80		        lda plotX_lo
   637 32BC 48			        pha
   638 32BD A5 81		        lda plotX_hi
   639 32BF 48			        pha
   640 32C0 20 59 35		        jsr plotPoint
   641 32C3 68			        pla
   642 32C4 85 81		        sta plotX_hi
   643 32C6 68			        pla
   644 32C7 85 80		        sta plotX_lo
   645
   646 				        ; plot point 7: (cx + circY, cy - circX)
   647 32C9 A5 9B		        lda cx
   648 32CB 18			        clc
   649 32CC 65 A0		        adc circY
   650 32CE 85 80		        sta plotX_lo
   651 32D0 A5 9C		        lda cx_hi
   652 32D2 69 00		        adc #0
   653 32D4 85 81		        sta plotX_hi
   654 32D6 A5 9D		        lda cy
   655 32D8 38			        sec
   656 32D9 E5 9F		        sbc circX
   657 32DB 85 82		        sta plotY
   658
   659 32DD A5 80		        lda plotX_lo
   660 32DF 48			        pha
   661 32E0 A5 81		        lda plotX_hi
   662 32E2 48			        pha
   663 32E3 20 59 35		        jsr plotPoint
   664 32E6 68			        pla
   665 32E7 85 81		        sta plotX_hi
   666 32E9 68			        pla
   667 32EA 85 80		        sta plotX_lo
   668
   669 				        ; plot point 8: (cx - circY, cy - circX)
   670 32EC A5 9B		        lda cx
   671 32EE 38			        sec
   672 32EF E5 A0		        sbc circY
   673 32F1 85 80		        sta plotX_lo
   674 32F3 A5 9C		        lda cx_hi
   675 32F5 E9 00		        sbc #0
   676 32F7 85 81		        sta plotX_hi
   677 32F9 A5 9D		        lda cy
   678 32FB 38			        sec
   679 32FC E5 9F		        sbc circX
   680 32FE 85 82		        sta plotY
   681
   682 3300 A5 80		        lda plotX_lo
   683 3302 48			        pha
   684 3303 A5 81		        lda plotX_hi
   685 3305 48			        pha
   686 3306 20 59 35		        jsr plotPoint
   687 3309 68			        pla
   688 330A 85 81		        sta plotX_hi
   689 330C 68			        pla
   690 330D 85 80		        sta plotX_lo
   691
   692 				        ; advance circX
   693 330F E6 9F		        inc circX
   694
   695 				        ; check sign of cerr
   696 3311 A5 A2		        lda cerr_hi
   697 3313 30 19		        bmi update_negative     ; cerr < 0
   698
   699 				        ; positive path: cerr >= 0
   700 3315 C6 A0		        dec circY               ; circY = circY - 1
   701 3317 A5 9F		        lda circX
   702 3319 38			        sec
   703 331A E5 A0		        sbc circY               ; A = circX - circY
   704 331C 0A			        asl                     ; A = 2*(circX-circY)
   705 331D 18			        clc
   706 331E 69 01		        adc #1                  ; A = 2*(circX-circY) + 1
   707 3320 18			        clc
   708 3321 65 A1		        adc cerr_lo
   709 3323 85 A1		        sta cerr_lo
   710 3325 A5 A2		        lda cerr_hi
   711 3327 69 00		        adc #0
   712 3329 85 A2		        sta cerr_hi
   713 332B 4C 3F 33		        jmp check_done          ; skip negative path
   714
   715 332E			update_negative:
   716 				        ; negative path: cerr < 0
   717 332E A5 9F		        lda circX
   718 3330 0A			        asl                     ; A = 2*circX
   719 3331 18			        clc
   720 3332 69 01		        adc #1                  ; A = 2*circX + 1
   721 3334 18			        clc
   722 3335 65 A1		        adc cerr_lo
   723 3337 85 A1		        sta cerr_lo
   724 3339 A5 A2		        lda cerr_hi
   725 333B 69 00		        adc #0
   726 333D 85 A2		        sta cerr_hi
   727 				                                ; fall through to check_done
   728
   729 333F			check_done:
   730 333F A5 9F		        lda circX
   731 3341 C5 A0		        cmp circY
   732 3343 90 03		        bcc keep_going      ; circX < circY — short forward branch
   733 3345 F0 01		        beq keep_going      ; circX = circY — short forward branch
   734 3347 60			        rts                 ; circX > circY — done!
   735 3348			keep_going:
   736 3348 4C F7 31		        jmp circleloop      ; jump back — unlimited range
   737 				        .endp
   738
   739
   740 				; =====================================================================
   741 				; fightAttract
   742 				; Call this every frame in your stop loop to prevent attract mode
   743 				; from desaturating your colors
   744 				; ON ENTRY: nothing
   745 				; ON EXIT:  attract mode defeated for this frame
   746 				;======================================================================
   747 334B			        .proc fightAttract
   748
   749 				        ; defeat attract mode and set colors
   750 334B A9 00 85 4D		        mva #0    ATRACT
   751 334F A9 FF 85 4E		        mva #$FF  ATRMSK
   752
   753 3353 60			        rts
   754 				        .endp
   755
   756 				; =====================================================================
   757 				; Clear the screen
   758
   759 3354			        .proc clearScreen
   760
   761 				; initialize pointer from SAVMSC
   762 3354 A5 58		        lda SAVMSC
   763 3356 85 85		        sta scrptr_lo
   764 3358 A5 59		        lda SAVMSC+1
   765 335A 85 86		        sta scrptr_hi
   766
   767 				; here we have a nested loop the iner loop will start at 0 and end at 255. 
   768 				; When Y overflows from 255 to 0, bne does NOT branch (falls through)
   769 				; because Y equals zero — exiting the inner loop into the outer loop.
   770
   771 335C A2 1E		        ldx #30             ; X = 30 pages to clear
   772 335E A0 00		        ldy #0              ; Y = byte index within page
   773
   774 3360			clearpage:
   775 3360 A9 00		        lda #$00
   776 3362 91 85		        sta (scrptr_lo),y   ; write $00
   777 3364 C8			        iny                 ; next byte
   778 3365 D0 F9		        bne clearpage       ; inner loop — 256 bytes
   779
   780 3367 E6 86		        inc scrptr_hi       ; advance to next page
   781 3369 CA			        dex                 ; X = X - 1
   782 336A D0 F4		        bne clearpage       ; outer loop — 30 pages
   783
   784 336C 60			        rts
   785 				        .endp
   786
   787
   788 				; =====================================================================
   789 				; Open Graphics Mode 8
   790
   791 336D			        .proc openGR8
   792
   793 				; =====================================================================
   794 				; STEP 1: Close IOCB6
   795 				; Good practice to close before opening — ensures clean state.
   796 				; ON ENTRY: X must contain IOCB number × $10 ($60 for IOCB6)
   797 				; ON ENTRY: ICCOM must contain the command ($0C = CLOSE)
   798 				; ON EXIT:  IOCB6 is closed and ready to be reopened
   799 				; =====================================================================
   800 336D A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
   801 336F A9 0C		        lda #$0C                    ; A = $0C        (CLOSE command)
   802 3371 9D 42 03		        sta ICCOM,x                 ; ICCOM = $0C    (store command in IOCB6)
   803 3374 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute the close)
   804
   805 				; =====================================================================
   806 				; STEP 2: Open Graphics Mode 8
   807 				; Fills in all IOCB6 fields then calls CIOV to execute the open.
   808 				; CIO sets up the display list, allocates screen RAM, configures
   809 				; ANTIC — everything needed for graphics mode automatically.
   810 				; ON ENTRY: nothing required
   811 				; ON EXIT:  GR.8 screen is active, SAVMSC points to screen RAM
   812 				; =====================================================================
   813
   814
   815 				;   Draw yellow pixels on the Atari 800XL in Graphics Mode 8
   816 				;   Uses CIO (Central I/O) to open the graphics mode, then writes
   817 				;   pixel data directly to screen RAM.
   818 				;   GR.8:   320 pixels wide × 192 tall   1 bit per pixel     2 colors
   819 				;   GR.8:   40 bytes × 192 rows = 7,680 bytes
   820 				;   GR.8:   320 pixels ÷ 8 pixels per byte = 40 bytes per row
   821 				;   GR.8 byte:  P P P P P P P P
   822 				;               | | | | | | | |
   823 				;               7 6 5 4 3 2 1 0   (8 pixels, 1 bit each, on or off)
   824
   825 3377 A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
   826 3379 A9 03		        lda #$03                    ; A = $03        (OPEN command)
   827 337B 9D 42 03		        sta ICCOM,x                 ; ICCOM = $03    (store open command)
   828 337E A9 D3		        lda #<scrname               ; A = low byte of "S:" string address
   829 3380 9D 44 03		        sta ICBAL,x                 ; ICBAL = low byte (tell CIO device name location)
   830 3383 A9 35		        lda #>scrname               ; A = high byte of "S:" string address
   831 3385 9D 45 03		        sta ICBAH,x                 ; ICBAH = high byte
   832 3388 A9 08		        lda #$08                    ; A = $08        (graphics mode 8)
   833 338A 9D 4B 03		        sta ICAX2,x                 ; ICAX2 = $08    (store graphics mode number)
   834 338D A9 0C		        lda #$0C                    ; A = $0C        (read/write access)
   835 338F 9D 4A 03		        sta ICAX1,x                 ; ICAX1 = $0C    (store access mode)
   836 3392 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute open — sets up entire graphics mode!)
   837
   838 				; Step 3: Setup color registers
   839 				; change COLPF1 to change pixel color
   840
   841 3395 A9 1E 8D C5 02	        mva #$1E  $02C5     ; COLPF1 = yellow (foreground - pixel color)
   842 339A A9 00 8D C6 02	        mva #$00  $02C6     ; COLPF2 = black (background)
   843 339F A9 00 8D C8 02	        mva #$00  $02C8     ; COLBK  = black (border)
   844
   845 33A4 60			        rts
   846 				        .endp
   847
   848 				;=========================================================================================
   849 				; draw a line using Bresenham's algorithm
   850
   851 33A5			        .proc drawLine
   852
   853 				        ; first step, compute:
   854 				        ; dx = x2 - x1    (16-bit subtraction)
   855 				        ; dy = y2 - y1    (8-bit subtraction)
   856
   857 33A5 A5 92		        lda y2          ; A = Y2
   858 33A7 38			        sec             ; set carry
   859 33A8 E5 8F		        sbc y1          ; A = A - Y1
   860 33AA 85 95		        sta dy          ; dy = A
   861
   862 33AC A5 90		        lda x2          ; A = x2 (low byte)
   863 33AE 38			        sec             ; set carry
   864 33AF E5 8D		        sbc x1          ; A = A - X1 (low byte)
   865 33B1 85 93		        sta dx_lo       ; save low byte, but do not re-set carry
   866
   867 33B3 A5 91		        lda x2_hi       ; A = X2 (high byte)
   868 33B5 E5 8E		        sbc x1_hi       ; A = A - X1 (high byte)
   869 33B7 85 94		        sta dx_hi       ; save high byte
   870
   871 				        ; check for vertical line (dx = 0)
   872 33B9 A5 93		        lda dx_lo
   873 33BB 05 94		        ora dx_hi       ; OR low and high bytes together
   874 33BD D0 33		        bne not_vertical ; if result != 0, not vertical
   875
   876 				        ; handle vertical line
   877 				        ; initialize position first!
   878 33BF A5 8D		        lda x1
   879 33C1 85 80		        sta plotX_lo
   880 33C3 A5 8E		        lda x1_hi
   881 33C5 85 81		        sta plotX_hi
   882 33C7 A5 8F		        lda y1
   883 33C9 85 82		        sta plotY
   884
   885 				        ; just loop Y from y1 to y2
   886 33CB			vertical_loop:
   887 33CB A5 80		        lda plotX_lo    ; save plotX before plotPoint destroys it
   888 33CD 48			        pha
   889 33CE A5 81		        lda plotX_hi
   890 33D0 48			        pha
   891 				        
   892 33D1 20 59 35		        jsr plotPoint
   893 				        
   894 33D4 68			        pla             ; restore plotX
   895 33D5 85 81		        sta plotX_hi
   896 33D7 68			        pla
   897 33D8 85 80		        sta plotX_lo
   898 				        
   899 33DA E6 82		        inc plotY
   900 33DC A5 82		        lda plotY
   901 33DE C5 92		        cmp y2
   902 33E0 D0 E9		        bne vertical_loop
   903 				        
   904 				        ; plot final point
   905 33E2 A5 80		        lda plotX_lo
   906 33E4 48			        pha
   907 33E5 A5 81		        lda plotX_hi
   908 33E7 48			        pha
   909 33E8 20 59 35		        jsr plotPoint
   910 33EB 68			        pla
   911 33EC 85 81		        sta plotX_hi
   912 33EE 68			        pla
   913 33EF 85 80		        sta plotX_lo
   914 				        
   915 33F1 60			        rts
   916
   917 33F2			not_vertical:
   918 				        ; continue with normal Bresenham...
   919
   920 				        ; initialize current position to start point
   921 33F2 A5 8D		        lda x1          ; A = X1
   922 33F4 85 80		        sta plotX_lo    ; plotX_lo = A
   923 33F6 A5 8E		        lda x1_hi       ; A = X1_hi
   924 33F8 85 81		        sta plotX_hi    ; plotX_hi = A
   925 33FA A5 8F		        lda y1          ; A = Y1
   926 33FC 85 82		        sta plotY       ; plotY = A
   927
   928 				        ; initialize error to 0
   929 33FE A9 00 85 96		        mva #0 err_lo           ; err_lo = 0
   930 3402 A9 00 85 97		        mva #0 err_hi           ; err_hi = 0
   931
   932 3406			lineloop:
   933 				        ; save plotX before plotPoint destroys it
   934 3406 A5 80		        lda plotX_lo
   935 3408 48			        pha
   936 3409 A5 81		        lda plotX_hi
   937 340B 48			        pha
   938
   939 340C 20 59 35		        jsr plotPoint
   940
   941 				        ; restore plotX after plotPoint
   942 340F 68			        pla
   943 3410 85 81		        sta plotX_hi
   944 3412 68			        pla
   945 3413 85 80		        sta plotX_lo
   946
   947 				; add dy to error accumulator (16-bit + 8-bit addition)
   948 3415 A5 96		        lda err_lo              ; A = err_lo
   949 3417 18			        clc                     ; clear carry
   950 3418 65 95		        adc dy                  ; A += dy
   951 341A 85 96		        sta err_lo              ; err_lo = A
   952 341C A5 97		        lda err_hi              ; A = err_hi
   953 341E 69 00		        adc #0                  ; propagate carry trick. if the carry was set it gets added to the high byte
   954 3420 85 97		        sta err_hi              ; err_hi = A
   955
   956 				        ; check if error * 2 >= dx
   957 				        ; compute error + error (16-bit)
   958 3422 A5 96		        lda err_lo              ; A = err_lo
   959 3424 18			        clc                     ; clear carry
   960 3425 65 96		        adc err_lo              ; A += err_lo (err_lo * 2)
   961 3427 85 83		        sta temp_lo             ; temp_lo = A
   962 3429 A5 97		        lda err_hi              ; A = err_hi
   963 342B 65 97		        adc err_hi              ; A += err_hi ((err_hi * 2) + carry)
   964 342D 85 84		        sta temp_hi             ; temp_hi = A
   965
   966 				        ; compare temp (error*2) to dx
   967 				        ; 16-bit comparison: check high byte first, then low byte
   968 342F A5 84		        lda temp_hi     ; A = temp_hi
   969 3431 C5 94		        cmp dx_hi       ; Does temp_hi == dx_hi? 
   970 3433 90 17		        bcc skip_y      ; temp_hi < dx_hi, no Y step needed (branch if carry is clear)
   971 3435 D0 06		        bne do_y_step   ; temp_hi > dx_hi, Y step needed (branch if not equal)
   972 3437 A5 83		        lda temp_lo     ; A = temp_lo (high bytes equal, check low bytes (if we got here, high bytes are equal))
   973 3439 C5 93		        cmp dx_lo       ; Does temp_lo == dx_lo?
   974 343B 90 0F		        bcc skip_y      ; temp_lo < dx_lo, no Y step needed
   975
   976 343D			do_y_step:
   977 343D E6 82		        inc plotY       ; y = y + 1
   978
   979 				        ; error = error - dx (16-bit subtraction)
   980 343F A5 96		        lda err_lo      ; A = err_lo
   981 3441 38			        sec             ; set the carry
   982 3442 E5 93		        sbc dx_lo       ; A -= dx_lo
   983 3444 85 96		        sta err_lo      ; err_lo = A
   984 3446 A5 97		        lda err_hi      ; A = err_hi
   985 3448 E5 94		        sbc dx_hi       ; A -= dex_hi
   986 344A 85 97		        sta err_hi      ; err_hi = A
   987
   988 344C			skip_y:
   989 				        ; advance x (16-bit increment)
   990 344C E6 80		        inc plotX_lo            ; plotX_lo++
   991 344E D0 02		        bne lineloop_check      ; if no overflow, check if done 
   992 				                                ; if plotX_lo != 0 JUMP FORWARD to lineloop_check
   993 3450 E6 81		        inc plotX_hi            ; handle overflow from low to high byte
   994 				                                ; only reaches here if plotX_lo overflowed to 0
   995
   996 3452			lineloop_check:
   997 				        ; are we done? compare plotX to x2
   998 3452 A5 80		        lda plotX_lo            ; A = plotX_lo
   999 3454 C5 90		        cmp x2                  ; test: A = X2 ?
  1000 3456 D0 AE		        bne lineloop            ; not done, keep going
  1001 				                                ; if plotX_lo != x2 JUMP BACK to lineloop
  1002 3458 A5 81		        lda plotX_hi            ; A = plotX_hi
  1003 345A C5 91		        cmp x2_hi               ; test: A = x2_hi ?
  1004 345C D0 A8		        bne lineloop            ; not done, keep going
  1005 				                                ; if plotX_hi != x2_hi JUMP BACK to lineloop
  1006 				                                ; if both match we fall through - done!
  1007
  1008 				        
  1009
  1010 345E 60			        rts
  1011 				        .endp
  1012
