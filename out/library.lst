    24 				; =====================================================================
    25 				; CIO (Central I/O) constants
    26 				; CIO is the Atari OS I/O system. We use it to open graphics mode.
    27 				; Each I/O channel uses an IOCB (I/O Control Block) — a fixed block
    28 				; of memory containing command, device, buffer address, and aux bytes.
    29 				; We use IOCB6 (base address $0360) for graphics.
    30 				; X register = $60 tells CIOV which IOCB to use (IOCB6).
    31 				; =====================================================================
    32 = E456			CIOV    = $E456     ; OS CIO entry point — call jsr CIOV to execute
    33 = 0342			ICCOM   = $0342     ; IOCB6 command register
    34 				                    ;   $03 = OPEN   (open a device)
    35 				                    ;   $0C = CLOSE  (close a device)
    36 = 0344			ICBAL   = $0344     ; IOCB6 buffer address low byte
    37 				                    ;   for OPEN: points to device name string "S:"
    38 = 0345			ICBAH   = $0345     ; IOCB6 buffer address high byte
    39 				                    ;   together with ICBAL forms 16-bit pointer to "S:"
    40 = 034A			ICAX1   = $034A     ; IOCB6 auxiliary byte 1
    41 				                    ;   for OPEN: $0C = read/write access mode
    42 = 034B			ICAX2   = $034B     ; IOCB6 auxiliary byte 2
    43 				                    ;   for OPEN: graphics mode number (8 = GR.8)
    44
    45 				; =====================================================================
    46 				; Screen RAM pointer
    47 				; After CIO opens GR.8, the OS stores the address of screen RAM
    48 				; in SAVMSC (two bytes). $58 = low byte, $59 = high byte.
    49 				; On our 800XL PAL system screen RAM ends up at $B060.
    50 				; =====================================================================
    51 = 0058			SAVMSC  = $58       ; zero page address — low byte of screen RAM address
    52 				                    ; $59 automatically contains the high byte
    53
    54 				; =====================================================================
    55 				; Attract mode constants
    56 				; The Atari OS has an attract mode that kicks in after inactivity
    57 				; to prevent screen burn-in. It does this by desaturating all colors
    58 				; making everything appear as shades of grey/blue.
    59 				; We must continuously reset these in our main loop to keep colors!
    60 				; =====================================================================
    61 = 004D			ATRACT  = $4D       ; attract mode counter — OS increments this each frame
    62 				                    ; when it reaches a threshold attract mode activates
    63 				                    ; we keep writing 0 to prevent it from activating
    64 = 004E			ATRMSK  = $4E       ; attract mode color mask
    65 				                    ; OS ANDs all colors with this value
    66 				                    ; $FE strips hue leaving only luminance (grey/blue)
    67 				                    ; $FF = full color (no masking) — what we want
