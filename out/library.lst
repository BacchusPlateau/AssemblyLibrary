   231 				; DATA
   232 				; =====================================================================
   233 30B9 53 3A 9B		scrname .byte 'S:',$9B             ; device name string for CIO OPEN
   234 				                                    ; 'S:' = screen device
   235 				                                    ; $9B  = ATASCII end-of-line terminator
     3
     4 30BC			        org $2000
     5
     6 2000			        .proc main
     7 				    
     8 				        ;=============================================================
     9 				        ; print a string example
    10 				        ;
    11 				        ;mva #1 csrhinh                  ; hide the cursor
    12 				        ;mva #6 rowcrs                   ; set output row
    13 				        ;mva #10 colcrs                  ; set output column
    14 				        
    15 				        ;mva #<string1 strptr_lo         ; low byte of string1 address
    16 				        ;mva #>string1 strptr_hi         ; high byte o f string1 address
    17 				        ;jsr print_string                ; print the string
    18
    19 				        ;jmp stop                        ; stop is inside routines.asm
    20 				        ;=============================================================
    21
    22 				;======================================================
    23 				; draw pixels example
    24 				;======================================================
    25
    26 				        ; disable BASIC ROM
    27 2000-20B9> 78		        sei                 ; disable interrupts during memory switch
    28 2001 AD 01 D3		        lda $D301           ; read PORTB
    29 2004 09 02		        ora #$02            ; set bit 1 = disable BASIC
    30 2006 8D 01 D3		        sta $D301           ; write back
    31 2009 58			        cli                 ; re-enable interrupts
    32
    33 				; =====================================================================
    34 				; STEP 1: Close IOCB6
    35 				; Good practice to close before opening — ensures clean state.
    36 				; ON ENTRY: X must contain IOCB number × $10 ($60 for IOCB6)
    37 				; ON ENTRY: ICCOM must contain the command ($0C = CLOSE)
    38 				; ON EXIT:  IOCB6 is closed and ready to be reopened
    39 				; =====================================================================
    40 200A A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
    41 200C A9 0C		        lda #$0C                    ; A = $0C        (CLOSE command)
    42 200E 9D 42 03		        sta ICCOM,x                 ; ICCOM = $0C    (store command in IOCB6)
    43 2011 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute the close)
    44
    45 				; =====================================================================
    46 				; STEP 2: Open Graphics Mode 8
    47 				; Fills in all IOCB6 fields then calls CIOV to execute the open.
    48 				; CIO sets up the display list, allocates screen RAM, configures
    49 				; ANTIC — everything needed for graphics mode automatically.
    50 				; ON ENTRY: X must contain $60 (IOCB6)
    51 				; ON EXIT:  GR.8 screen is active, SAVMSC points to screen RAM
    52 				; =====================================================================
    53 2014 A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
    54 2016 A9 03		        lda #$03                    ; A = $03        (OPEN command)
    55 2018 9D 42 03		        sta ICCOM,x                 ; ICCOM = $03    (store open command)
    56 201B A9 B9		        lda #<scrname               ; A = low byte of "S:" string address
    57 201D 9D 44 03		        sta ICBAL,x                 ; ICBAL = low byte (tell CIO device name location)
    58 2020 A9 30		        lda #>scrname               ; A = high byte of "S:" string address
    59 2022 9D 45 03		        sta ICBAH,x                 ; ICBAH = high byte
    60 2025 A9 08		        lda #$08                    ; A = $08        (graphics mode 8)
    61 2027 9D 4B 03		        sta ICAX2,x                 ; ICAX2 = $08    (store graphics mode number)
    62 202A A9 0C		        lda #$0C                    ; A = $0C        (read/write access)
    63 202C 9D 4A 03		        sta ICAX1,x                 ; ICAX1 = $0C    (store access mode)
    64 202F 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute open — sets up entire graphics mode!)
    65
    66 				; =====================================================================
    67 				; STEP 3: Clear Screen RAM to black
    68 				; Screen RAM at $B060 may contain garbage from previous programs.
    69 				; We fill 256 bytes with $00 (black = all pixels off).
    70 				; Note: this only clears the first 256 bytes (one page) of screen RAM.
    71 				; Full screen RAM is 3200 bytes — we'd need a 16-bit loop for all of it.
    72 				; $00 = %00000000 = all 4 pixels in byte = background color (black)
    73 				; =====================================================================
    74
    75 2032 A5 58		        lda SAVMSC      ; A = memory[$58]  (low byte of screen RAM address from OS)
    76 2034 85 85		        sta scrptr_lo   ; store in scrptr_lo ($85)
    77 2036 A5 59		        lda SAVMSC+1    ; A = memory[$59]  (high byte of screen RAM address from OS)
    78 2038 85 86		        sta scrptr_hi   ; store in scrptr_hi ($86)
    79
    80 203A A0 00		        ldy #0
    81 203C			clearscreen:
    82 203C A9 00		        lda #$00
    83 203E 91 85		        sta (scrptr_lo),y   ; write $00 to memory[scrptr + Y]
    84 2040 C8			        iny
    85 2041 D0 F9		        bne clearscreen
    86
    87 				        ; defeat attract mode and set colors
    88 2043 A9 00 85 4D		        mva #0    ATRACT
    89 2047 A9 FF 85 4E		        mva #$FF  ATRMSK
    90 204B A9 1E 8D C5 02	        mva #$1E  $02C5     ; COLPF1 = yellow
    91 2050 A9 00 8D C6 02	        mva #$00  $02C6     ; COLPF2 = black
    92 2055 A9 00 8D C8 02	        mva #$00  $02C8     ; COLBK  = black
    93
    94 				        ; upper left
    95 205A A9 00 85 80		        mva #0    plotX_lo
    96 205E A9 00 85 81		        mva #0    plotX_hi
    97 2062 A9 00 85 82		        mva #0    plotY
    98 2066 20 3F 30		        jsr plotPoint
    99
   100 				        ; upper right
   101 2069 A9 3F 85 80		        mva #$3F  plotX_lo
   102 206D A9 01 85 81		        mva #$01  plotX_hi
   103 2071 A9 00 85 82		        mva #0    plotY
   104 2075 20 3F 30		        jsr plotPoint
   105
   106 				        ; lower left
   107 2078 A9 00 85 80		        mva #0    plotX_lo
   108 207C A9 00 85 81		        mva #0    plotX_hi
   109 2080 A9 BF 85 82		        mva #191  plotY
   110 2084 20 3F 30		        jsr plotPoint
   111
   112 				        ; lower right
   113 2087 A9 3F 85 80		        mva #$3F  plotX_lo
   114 208B A9 01 85 81		        mva #$01  plotX_hi
   115 208F A9 BF 85 82		        mva #191  plotY
   116 2093 20 3F 30		        jsr plotPoint
   117
   118 2096 A9 1E 8D C8 02	        mva #$1E  $02C8     ; COLBK = bright yellow  (pixels where bit=1)
   119 209B A9 00 8D C6 02	        mva #$00  $02C6     ; COLPF2 = black         (background where bit=0)
   120
   121 20A0			halt:
   122 20A0 A9 00 85 4D		        mva #0    ATRACT
   123 20A4 A9 FF 85 4E		        mva #$FF  ATRMSK
   124 20A8 A9 1E 8D C5 02	        mva #$1E  $02C5     ; COLPF1 = bright yellow pixels
   125 20AD A9 00 8D C6 02	        mva #$00  $02C6     ; COLPF2 = black background
   126 20B2 A9 00 8D C8 02	        mva #$00  $02C8     ; COLBK  = black border
   127 20B7 4C A0 20		        jmp halt
   128
   129
   130 				        .endp
